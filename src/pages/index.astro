    .promo-stage { padding-top: 5.5rem; }
    .promo-heading { margin-bottom: 2.5rem; }
    .promo-plans { display: flex; gap: .8rem; overflow-x: auto; margin-right: -16px; padding: 0 16px 1rem 0; scroll-snap-type: x mandatory; scrollbar-width: none; }
    .promo-plans::-webkit-scrollbar { display: none; }
    .promo-plan { min-width: min(78vw, 320px); min-height: 300px; scroll-snap-align: start; }
    .promo-benefits { display: grid; grid-template-columns: 1fr 1fr; }
    .promo-benefits span { border-radius: 14px; }
    .promo-cta { align-items: stretch; flex-direction: column; padding: 1.2rem; }
    .promo-cta .button { width: 100%; }
    .journal-grid { display: flex; gap: .9rem; overflow-x: auto; margin-right: -16px; padding: 0 16px .8rem 0; scroll-snap-type: x mandatory; scrollbar-width: none; }
    .journal-grid::-webkit-scrollbar { display: none; }
    .journal-card { min-width: min(84vw, 340px); scroll-snap-align: start; scroll-snap-stop: always; }
    .journal-card.featured { grid-column: auto; }
    .journal-image, .featured .journal-image { aspect-ratio: 4 / 3; }
    .journal-head { align-items: start; flex-direction: column; }
    .quote-mark { display: none; }
    .review-head { grid-template-columns: 1fr; }
    .field-caption { display: none; }
    .welcome-promo { width: calc(100vw - 24px); max-height: calc(100svh - 24px); border-radius: 20px; }
    .welcome-promo-card { max-height: calc(100svh - 24px); }
    .welcome-promo header, .welcome-promo footer { padding: .7rem .75rem; }
    .welcome-promo header strong { font-size: .88rem; }
    .welcome-promo header button { width: 36px; height: 36px; flex-basis: 36px; }
    .welcome-promo footer p small { max-width: 150px; }
  }

  @media (max-height: 680px) {
    .welcome-promo { width: min(calc(100vw - 24px), 340px); }
    .welcome-promo header span, .welcome-promo footer p small { display: none; }
    .welcome-promo header, .welcome-promo footer { padding-block: .55rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .welcome-promo, .welcome-promo::backdrop { transition: none; }
  }
</style>

<script>
  const parallax = document.querySelector('[data-parallax]');
  if (parallax && window.matchMedia('(hover: hover) and (pointer: fine)').matches && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    window.addEventListener('pointermove', event => {
      const x = (event.clientX / window.innerWidth - .5) * 10;
      const y = (event.clientY / window.innerHeight - .5) * 10;
      (parallax as HTMLElement).style.translate = `${x}px ${y}px`;
    }, { passive: true });
  }

  const welcomePromo = document.querySelector<HTMLDialogElement>('#welcome-promo');
  const welcomePromoImage = welcomePromo?.querySelector<HTMLImageElement>('img[data-src]');
  const welcomePromoKey = 'binnet-welcome-promo-seen-v2';
  let welcomePromoTriggered = false;
  const closeWelcomePromo = () => welcomePromo?.close();
  const showWelcomePromo = () => {
    if (welcomePromo && !welcomePromo.open) welcomePromo.showModal();
  };
  const triggerWelcomePromo = () => {
    if (!welcomePromo || welcomePromoTriggered || document.visibilityState !== 'visible') return;
    welcomePromoTriggered = true;
    window.removeEventListener('scroll', checkPromoIntent);
    if (welcomePromoImage) {
      welcomePromoImage.src = welcomePromoImage.dataset.src || '';
      welcomePromoImage.srcset = welcomePromoImage.dataset.srcset || '';
      welcomePromoImage.sizes = welcomePromoImage.dataset.sizes || '';
      if (welcomePromoImage.complete) showWelcomePromo();
      else welcomePromoImage.addEventListener('load', showWelcomePromo, { once: true });
      window.setTimeout(showWelcomePromo, 1400);
    } else showWelcomePromo();
    try { sessionStorage.setItem(welcomePromoKey, '1'); } catch {}
  };
  const checkPromoIntent = () => {
    const pageHeight = document.documentElement.scrollHeight - window.innerHeight;
    if (pageHeight > 0 && window.scrollY / pageHeight >= .32) triggerWelcomePromo();
  };

  document.querySelector('#welcome-promo-close')?.addEventListener('click', closeWelcomePromo);
  welcomePromo?.addEventListener('click', event => {
    if (event.target === welcomePromo) closeWelcomePromo();
  });

  try {
    if (welcomePromo && sessionStorage.getItem(welcomePromoKey) !== '1') {
      window.addEventListener('scroll', checkPromoIntent, { passive: true });
      window.setTimeout(triggerWelcomePromo, 8000);
    }
  } catch {
    window.setTimeout(triggerWelcomePromo, 8000);
  }

  const reviewTrack = document.querySelector<HTMLElement>('[data-review-slider]');
  const reviewCards = Array.from(document.querySelectorAll<HTMLElement>('[data-review-card]'));
  const reviewDots = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-review-dot]'));
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let activeReview = 0;
  let reviewFrame = 0;

  const setActiveReview = (index: number) => {
    activeReview = Math.max(0, Math.min(index, reviewCards.length - 1));
    reviewDots.forEach((dot, dotIndex) => {
      dot.classList.toggle('active', dotIndex === activeReview);
      dot.setAttribute('aria-current', dotIndex === activeReview ? 'true' : 'false');
    });
  };
  const goToReview = (index: number) => {
    if (!reviewTrack || !reviewCards.length) return;
    const nextIndex = (index + reviewCards.length) % reviewCards.length;
    reviewTrack.scrollTo({ left: reviewCards[nextIndex].offsetLeft - reviewTrack.offsetLeft, behavior: reducedMotion ? 'auto' : 'smooth' });
    setActiveReview(nextIndex);
  };

  document.querySelector('[data-review-prev]')?.addEventListener('click', () => goToReview(activeReview - 1));
  document.querySelector('[data-review-next]')?.addEventListener('click', () => goToReview(activeReview + 1));
  reviewDots.forEach((dot, index) => dot.addEventListener('click', () => goToReview(index)));
  reviewTrack?.addEventListener('keydown', event => {
    if (event.key === 'ArrowLeft') { event.preventDefault(); goToReview(activeReview - 1); }
    if (event.key === 'ArrowRight') { event.preventDefault(); goToReview(activeReview + 1); }
  });
  reviewTrack?.addEventListener('scroll', () => {
    window.cancelAnimationFrame(reviewFrame);
    reviewFrame = window.requestAnimationFrame(() => {
      if (!reviewTrack) return;
      const trackLeft = reviewTrack.getBoundingClientRect().left;
      const nearest = reviewCards.reduce((best, card, index) => {
        const distance = Math.abs(card.getBoundingClientRect().left - trackLeft);
        return distance < best.distance ? { index, distance } : best;
      }, { index: 0, distance: Number.POSITIVE_INFINITY });
      setActiveReview(nearest.index);
    });
  }, { passive: true });
  setActiveReview(0);

</script>
