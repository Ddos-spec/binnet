---
import Layout from '../layouts/Layout.astro';

const pricingPlans = [
  { speed: '10 Mbps',  price: 'Rp 100.000', popular: false, color: '#1e5bb4' },
  { speed: '20 Mbps',  price: 'Rp 150.000', popular: false, color: '#1e5bb4' },
  { speed: '30 Mbps',  price: 'Rp 200.000', popular: true,  color: '#00b4d8' },
  { speed: '50 Mbps',  price: 'Rp 250.000', popular: false, color: '#1e5bb4' },
  { speed: '100 Mbps', price: 'Rp 350.000', popular: false, color: '#1e5bb4' },
];

const testimonials = [
  { name: 'Meisha',  text: 'Koneksi BINNET sangat stabil, tidak pernah putus saat work from home. Rekomendeasi banget!', avatar: '/media/3047-test1.jpg' },
  { name: 'Rudi',    text: 'Harga terjangkau, kecepatan sesuai paket. Customer service cepat respons. Puas!', avatar: '/media/3048-test2.jpg' },
  { name: 'Aula',    text: 'Sudah 2 tahun pakai BINNET, belum pernah kecewa. Internet lancar untuk streaming dan gaming.', avatar: '/media/3049-test3.jpg' },
  { name: 'Vera',    text: 'Pemasangan cepat, teknisi ramah. Sinyal kuat sampai ke seluruh rumah.', avatar: '/media/4456-author1.jpg' },
  { name: 'Chandra', text: 'Internet bisnis BINNET andal sekali. Cocok untuk operasional toko online saya.', avatar: '/media/4457-author2-2.jpg' },
  { name: 'Naimah',  text: 'Daftar mudah, langsung terpasang dalam 1 hari. Mantap!', avatar: '/media/2101-author-home2.jpg' },
];

const services = [
  {
    icon: '/media/968-wi-fi.svg',
    title: 'Internet Rumah',
    desc: 'Koneksi fiber optik stabil untuk kebutuhan streaming, gaming, dan belajar online.',
  },
  {
    icon: '/media/966-radio.svg',
    title: 'Internet Bisnis',
    desc: 'Bandwidth dedicated dengan SLA uptime tinggi untuk operasional bisnis Anda.',
  },
  {
    icon: '/media/967-satellite.svg',
    title: 'Pemasangan CCTV',
    desc: 'Layanan instalasi CCTV profesional untuk keamanan rumah dan kantor.',
  },
  {
    icon: '/media/965-charging.svg',
    title: 'Perbaikan Elektronik',
    desc: 'Servis dan perbaikan perangkat elektronik oleh teknisi berpengalaman.',
  },
];
---

<Layout title="Home" description="Koneksi Cepat Harga Hemat — PT Citra Bintang Net, ISP terpercaya untuk rumah dan bisnis Anda.">

  <!-- ── PROMO POPUP ─────────────────────────────── -->
  <div class="promo-overlay" id="promo-overlay" role="dialog" aria-modal="true" aria-label="Promo Terbatas">
    <div class="promo-modal">
      <div class="promo-header">
        <button class="promo-close" id="promo-close" aria-label="Tutup">✕</button>
        <div class="promo-tag">🔥 Promo Terbatas</div>
        <h2>Daftar Sekarang,<br/>Hemat <span>Hingga 30%!</span></h2>
        <p>Penawaran spesial untuk pelanggan baru bulan ini</p>
      </div>

      <div class="promo-body">
        <div class="promo-plans">
          <div class="promo-plan">
            <div class="promo-plan-speed">10 Mbps</div>
            <div class="promo-plan-price">
              <s>Rp 130.000</s><br/>
              <strong>Rp 100.000/bln</strong>
            </div>
          </div>
          <div class="promo-plan hot">
            <div class="promo-plan-speed">⭐ 30 Mbps</div>
            <div class="promo-plan-price">
              <s>Rp 280.000</s><br/>
              <strong>Rp 200.000/bln</strong>
            </div>
          </div>
          <div class="promo-plan">
            <div class="promo-plan-speed">50 Mbps</div>
            <div class="promo-plan-price">
              <s>Rp 330.000</s><br/>
              <strong>Rp 250.000/bln</strong>
            </div>
          </div>
          <div class="promo-plan">
            <div class="promo-plan-speed">100 Mbps</div>
            <div class="promo-plan-price">
              <s>Rp 450.000</s><br/>
              <strong>Rp 350.000/bln</strong>
            </div>
          </div>
        </div>

        <div class="promo-countdown">
          <span>⏱️ Promo berakhir dalam:</span>
          <span class="countdown-timer" id="promo-timer">10:00</span>
        </div>

        <div class="promo-cta">
          <a href="/contact-us" class="cta-main">Daftar Sekarang — Gratis Instalasi!</a>
          <a href="#" class="cta-skip" id="promo-skip">Lewati, lihat nanti</a>
        </div>
      </div>
    </div>
  </div>


  <!-- ── HERO ─────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="hero-eyebrow">PT Citra Bintang Net</p>
        <h1>Koneksi Cepat<br/><span>Harga Hemat</span></h1>
        <p class="hero-sub">Nikmati internet tanpa batas mulai dari <strong>100 ribuan saja</strong></p>
        <div class="hero-btns">
          <a href="/pricing" class="btn btn-primary">Lihat Pricelist</a>
          <a href="/contact-us" class="btn btn-outline">Daftar Sekarang</a>
        </div>
        <div class="hero-badges">
          <div class="badge-item">
            <span class="badge-num">4800+</span>
            <span class="badge-lbl">Pelanggan</span>
          </div>
          <div class="badge-divider"></div>
          <div class="badge-item">
            <span class="badge-num">99.9%</span>
            <span class="badge-lbl">Uptime</span>
          </div>
          <div class="badge-divider"></div>
          <div class="badge-item">
            <span class="badge-num">24/7</span>
            <span class="badge-lbl">Support</span>
          </div>
        </div>
      </div>
      <div class="hero-visual">
        <img src="/media/5216-img-layout1-05.png" alt="Internet BINNET" class="hero-img"/>
      </div>
    </div>
  </section>

  <!-- ── ABOUT STRIP ───────────────────────────────── -->
  <section class="about-strip">
    <div class="container about-inner">
      <div class="about-img">
        <img src="/media/6252-chatgpt-image-apr-18-2025-06_18_50-pm.png" alt="PT Citra Bintang Net"/>
      </div>
      <div class="about-text">
        <span class="section-label">About Us</span>
        <h2 class="section-title">PT Citra Bintang Net</h2>
        <p class="section-sub">BINNET adalah penyedia layanan internet (ISP) yang melayani pelanggan rumahan dan bisnis dengan teknologi terkini. Kami berkomitmen menghadirkan koneksi yang stabil, cepat, dan harga yang ramah di kantong.</p>
        <a href="/about-us" class="btn btn-primary" style="margin-top:1.5rem;display:inline-flex;">Selengkapnya</a>
      </div>
    </div>
  </section>

  <!-- ── PRICELIST ──────────────────────────────────── -->
  <section class="pricing-section">
    <div class="container">
      <div class="section-head">
        <span class="section-label">PRICELIST</span>
        <h2 class="section-title">Internet Terbaik Tanpa Biaya Mahal</h2>
        <p class="section-sub">Pilih paket sesuai kebutuhan Anda. Semua paket sudah termasuk instalasi gratis.</p>
      </div>

      <div class="pricing-grid">
        {pricingPlans.map(plan => (
          <div class={`pricing-card ${plan.popular ? 'popular' : ''}`}>
            {plan.popular && <div class="popular-badge">Terpopuler</div>}
            <div class="pricing-speed">{plan.speed}</div>
            <div class="pricing-price">{plan.price}<span>/bulan</span></div>
            <ul class="pricing-features">
              <li>✓ Unlimited Kuota</li>
              <li>✓ Instalasi Gratis</li>
              <li>✓ Support 24/7</li>
              <li>✓ Tanpa FUP</li>
            </ul>
            <a href="/contact-us" class={`btn ${plan.popular ? 'btn-primary' : 'btn-outline-blue'}`}>
              Daftar Sekarang
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── SERVICES ───────────────────────────────────── -->
  <section class="services-section">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Layanan Kami</span>
        <h2 class="section-title">Layanan Lengkap untuk Rumah Anda</h2>
      </div>

      <div class="services-grid">
        {services.map(s => (
          <div class="service-card">
            <div class="service-icon">
              <img src={s.icon} alt={s.title}/>
            </div>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
            <a href="/our-services" class="service-link">Pelajari lebih →</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── TESTIMONIALS ───────────────────────────────── -->
  <section class="testi-section">
    <div class="container">
      <div class="section-head centered">
        <span class="section-label">TESTIMONI</span>
        <h2 class="section-title">Apa Kata Pelanggan Kami?</h2>
      </div>

      <div class="testi-grid">
        {testimonials.map(t => (
          <div class="testi-card">
            <p class="testi-text">"{t.text}"</p>
            <div class="testi-author">
              <img src={t.avatar} alt={t.name}/>
              <strong>{t.name}</strong>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA BANNER ─────────────────────────────────── -->
  <section class="cta-banner">
    <div class="container cta-inner">
      <div>
        <h2>Siap Nikmati Internet Cepat?</h2>
        <p>Hubungi kami sekarang dan dapatkan instalasi gratis hari ini!</p>
      </div>
      <div class="cta-btns">
        <a href="/contact-us" class="btn btn-white">Hubungi Kami</a>
        <a href="/pricing" class="btn btn-outline-white">Lihat Paket</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── HERO ─────────────── */
  .hero {
    position: relative;
    background: linear-gradient(135deg, #0d2b5e 0%, #1a3c6e 50%, #1e5bb4 100%);
    overflow: hidden;
    padding: 5rem 0;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background: url('/media/5206-bg1-home05.png') center/cover no-repeat;
    opacity: .08;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  .hero-eyebrow {
    color: var(--cyan);
    font-size: .875rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    margin-bottom: .75rem;
  }
  .hero-text h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 900;
    color: #fff;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }
  .hero-text h1 span { color: var(--cyan); }
  .hero-sub { color: rgba(255,255,255,.8); font-size: 1.1rem; margin-bottom: 2rem; }
  .hero-sub strong { color: var(--yellow); }
  .hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
  .hero-badges {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    padding: 1.25rem 1.5rem;
    background: rgba(255,255,255,.08);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,.15);
    border-radius: 16px;
    width: fit-content;
  }
  .badge-item { text-align: center; }
  .badge-num { display: block; font-size: 1.5rem; font-weight: 800; color: #fff; }
  .badge-lbl { font-size: .75rem; color: rgba(255,255,255,.6); text-transform: uppercase; letter-spacing: .06em; }
  .badge-divider { width: 1px; height: 40px; background: rgba(255,255,255,.2); }
  .hero-visual { position: relative; }
  .hero-img { border-radius: 20px; box-shadow: 0 24px 64px rgba(0,0,0,.3); }

  /* BUTTONS */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: .8rem 1.75rem;
    border-radius: 10px;
    font-weight: 700;
    font-size: .9rem;
    transition: all .2s;
    cursor: pointer;
    border: 2px solid transparent;
  }
  .btn-primary { background: var(--cyan); color: var(--blue); }
  .btn-primary:hover { background: #00d0f0; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,180,216,.3); }
  .btn-outline { border-color: rgba(255,255,255,.4); color: #fff; }
  .btn-outline:hover { background: rgba(255,255,255,.1); }
  .btn-outline-blue { border-color: var(--blue-md); color: var(--blue-md); background: transparent; }
  .btn-outline-blue:hover { background: var(--blue-md); color: #fff; }
  .btn-white { background: #fff; color: var(--blue); }
  .btn-white:hover { background: #e8f4ff; }
  .btn-outline-white { border-color: rgba(255,255,255,.5); color: #fff; }
  .btn-outline-white:hover { background: rgba(255,255,255,.1); }

  /* ── ABOUT ────────────── */
  .about-strip { padding: 5rem 0; background: var(--off); }
  .about-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .about-img img { border-radius: 20px; box-shadow: var(--shadow); }

  /* ── PRICING ──────────── */
  .pricing-section { padding: 5rem 0; }
  .section-head { margin-bottom: 3rem; }
  .section-head.centered { text-align: center; }
  .section-head.centered .section-sub { margin: 0 auto; }
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.25rem;
  }
  .pricing-card {
    position: relative;
    border: 2px solid #e2e8f0;
    border-radius: var(--radius);
    padding: 2rem 1.25rem;
    text-align: center;
    transition: all .25s;
    background: #fff;
  }
  .pricing-card:hover { border-color: var(--blue-lt); box-shadow: 0 8px 32px rgba(30,91,180,.12); transform: translateY(-4px); }
  .pricing-card.popular { border-color: var(--cyan); box-shadow: 0 8px 32px rgba(0,180,216,.2); transform: translateY(-8px); }
  .popular-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--cyan);
    color: var(--blue);
    font-size: .72rem;
    font-weight: 800;
    padding: .25rem .85rem;
    border-radius: 999px;
    white-space: nowrap;
    letter-spacing: .05em;
    text-transform: uppercase;
  }
  .pricing-speed { font-size: 1.4rem; font-weight: 800; color: var(--blue); margin-bottom: .5rem; }
  .pricing-price { font-size: 1.6rem; font-weight: 900; color: var(--blue-lt); margin-bottom: 1.25rem; }
  .pricing-price span { font-size: .8rem; font-weight: 500; color: var(--muted); }
  .pricing-features { list-style: none; text-align: left; margin-bottom: 1.5rem; }
  .pricing-features li { font-size: .85rem; color: #374151; padding: .35rem 0; border-bottom: 1px solid #f1f5f9; }
  .pricing-features li:last-child { border: none; }

  /* ── SERVICES ─────────── */
  .services-section { padding: 5rem 0; background: var(--off); }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .service-card {
    background: #fff;
    border-radius: var(--radius);
    padding: 2rem 1.5rem;
    text-align: center;
    box-shadow: 0 2px 16px rgba(0,0,0,.06);
    transition: all .25s;
  }
  .service-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(30,91,180,.12); }
  .service-icon {
    width: 72px;
    height: 72px;
    background: linear-gradient(135deg, #e8f4ff, #cce8f8);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.25rem;
    padding: 1rem;
  }
  .service-icon img { width: 36px; height: 36px; }
  .service-card h3 { font-size: 1rem; font-weight: 700; color: var(--blue); margin-bottom: .5rem; }
  .service-card p { font-size: .875rem; color: var(--muted); margin-bottom: 1rem; }
  .service-link { font-size: .85rem; font-weight: 700; color: var(--blue-lt); transition: color .2s; }
  .service-link:hover { color: var(--cyan); }

  /* ── TESTIMONIALS ─────── */
  .testi-section { padding: 5rem 0; }
  .testi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .testi-card {
    background: var(--off);
    border-radius: var(--radius);
    padding: 1.75rem;
    border: 1px solid #e2e8f0;
    transition: all .2s;
  }
  .testi-card:hover { box-shadow: var(--shadow); transform: translateY(-2px); }
  .testi-text { font-size: .9rem; color: #374151; line-height: 1.75; margin-bottom: 1.25rem; font-style: italic; }
  .testi-author { display: flex; align-items: center; gap: .75rem; }
  .testi-author img { width: 42px; height: 42px; border-radius: 50%; object-fit: cover; }
  .testi-author strong { font-size: .9rem; color: var(--blue); }

  /* ── CTA ──────────────── */
  .cta-banner {
    background: linear-gradient(135deg, #1a3c6e, #1e5bb4);
    padding: 4rem 0;
    margin-top: 5rem;
  }
  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .cta-inner h2 { font-size: 1.75rem; font-weight: 800; color: #fff; margin-bottom: .5rem; }
  .cta-inner p { color: rgba(255,255,255,.75); }
  .cta-btns { display: flex; gap: 1rem; }

  /* ── RESPONSIVE ───────── */
  @media (max-width: 1024px) {
    .pricing-grid { grid-template-columns: repeat(3, 1fr); }
    .services-grid { grid-template-columns: repeat(2, 1fr); }
    .testi-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-visual { display: none; }
    .about-inner { grid-template-columns: 1fr; }
    .pricing-grid { grid-template-columns: repeat(2, 1fr); }
    .services-grid { grid-template-columns: 1fr; }
    .testi-grid { grid-template-columns: 1fr; }
    .cta-inner { flex-direction: column; text-align: center; }
  }
  @media (max-width: 480px) {
    .pricing-grid { grid-template-columns: 1fr; }
  }

  /* ── PROMO POPUP ────── */
  .promo-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.55);
    backdrop-filter: blur(4px);
    z-index: 9998;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity .35s, visibility .35s;
  }
  .promo-overlay.show {
    opacity: 1;
    visibility: visible;
  }
  .promo-modal {
    background: #fff;
    border-radius: 20px;
    overflow: hidden;
    max-width: 480px;
    width: 100%;
    box-shadow: 0 32px 80px rgba(0,0,0,.3);
    transform: scale(.9) translateY(20px);
    transition: transform .35s cubic-bezier(.34,1.56,.64,1);
    position: relative;
  }
  .promo-overlay.show .promo-modal {
    transform: scale(1) translateY(0);
  }
  .promo-header {
    background: linear-gradient(135deg, #1a3c6e 0%, #1e5bb4 60%, #00b4d8 100%);
    padding: 2rem 2rem 1.5rem;
    text-align: center;
    position: relative;
  }
  .promo-tag {
    display: inline-block;
    background: #ffd60a;
    color: #1a3c6e;
    font-size: .72rem;
    font-weight: 800;
    letter-spacing: .12em;
    text-transform: uppercase;
    padding: .3rem .9rem;
    border-radius: 999px;
    margin-bottom: 1rem;
    animation: pulse-badge 1.5s ease-in-out infinite;
  }
  @keyframes pulse-badge {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.06); }
  }
  .promo-header h2 {
    color: #fff;
    font-size: 1.5rem;
    font-weight: 900;
    line-height: 1.2;
    margin-bottom: .5rem;
  }
  .promo-header h2 span { color: #ffd60a; }
  .promo-header p {
    color: rgba(255,255,255,.8);
    font-size: .9rem;
  }
  .promo-close {
    position: absolute;
    top: .75rem;
    right: .75rem;
    width: 32px;
    height: 32px;
    background: rgba(255,255,255,.15);
    border: none;
    border-radius: 50%;
    color: #fff;
    font-size: 1.1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background .2s;
    line-height: 1;
  }
  .promo-close:hover { background: rgba(255,255,255,.3); }
  .promo-body {
    padding: 1.75rem 2rem 2rem;
  }
  .promo-plans {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .75rem;
    margin-bottom: 1.5rem;
  }
  .promo-plan {
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    padding: 1rem;
    text-align: center;
    transition: border-color .2s;
  }
  .promo-plan:hover { border-color: #00b4d8; }
  .promo-plan.hot { border-color: #ffd60a; background: #fffbeb; }
  .promo-plan-speed { font-size: 1.1rem; font-weight: 800; color: #1a3c6e; }
  .promo-plan-price { font-size: .85rem; color: #64748b; margin-top: .2rem; }
  .promo-plan-price s { color: #ef4444; }
  .promo-plan-price strong { color: #16a34a; font-weight: 700; }
  .promo-countdown {
    background: #f0f4f8;
    border-radius: 10px;
    padding: .85rem 1rem;
    display: flex;
    align-items: center;
    gap: .75rem;
    margin-bottom: 1.25rem;
    font-size: .85rem;
    color: #374151;
  }
  .countdown-timer {
    font-weight: 800;
    color: #ef4444;
    font-size: 1rem;
    letter-spacing: .05em;
    min-width: 60px;
  }
  .promo-cta {
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }
  .promo-cta a {
    display: block;
    text-align: center;
    padding: .9rem;
    border-radius: 10px;
    font-weight: 700;
    font-size: .95rem;
    transition: all .2s;
    text-decoration: none;
  }
  .promo-cta .cta-main {
    background: linear-gradient(135deg, #1e5bb4, #00b4d8);
    color: #fff;
  }
  .promo-cta .cta-main:hover { opacity: .9; transform: translateY(-2px); }
  .promo-cta .cta-skip {
    color: #94a3b8;
    font-size: .8rem;
    font-weight: 500;
  }
  .promo-cta .cta-skip:hover { color: #64748b; }
</style>

<script>
  // Promo popup logic
  (function() {
    if (sessionStorage.getItem('binnet-promo-closed')) return;
    
    const overlay = document.getElementById('promo-overlay');
    if (!overlay) return;

    // Show after 1.5s
    setTimeout(() => overlay.classList.add('show'), 1500);

    function close() {
      overlay.classList.remove('show');
      sessionStorage.setItem('binnet-promo-closed', '1');
    }

    document.getElementById('promo-close').addEventListener('click', close);
    document.getElementById('promo-skip').addEventListener('click', (e) => { e.preventDefault(); close(); });
    overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });

    // Countdown timer — 10 menit dari saat buka
    let total = 10 * 60;
    const timerEl = document.getElementById('promo-timer');
    const iv = setInterval(() => {
      if (total <= 0) { clearInterval(iv); return; }
      total--;
      const m = String(Math.floor(total / 60)).padStart(2, '0');
      const s = String(total % 60).padStart(2, '0');
      if (timerEl) timerEl.textContent = m + ':' + s;
    }, 1000);
  })();
</script>
