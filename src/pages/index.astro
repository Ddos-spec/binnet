  .journal-card h3 { font-family: 'Space Grotesk'; font-size: clamp(1.25rem, 2.2vw, 2rem); font-weight: 600; letter-spacing: -.04em; line-height: 1.15; }
  .journal-card p { margin-top: .8rem; color: #46617f; font-size: .86rem; line-height: 1.65; }

  @media (max-width: 1100px) {
    .hero-grid { grid-template-columns: 1fr .45fr; }
