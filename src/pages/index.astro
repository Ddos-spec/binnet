    .promo-content { width: 100%; }
    .service-row { grid-template-columns: 35px 75px 1fr 30px; gap: 1rem; }
    .service-image { width: 75px; height: 75px; }
    .service-row p { display: none; }
    .field-story { min-height: 90svh; }
    .field-image::after { background: linear-gradient(0deg, rgba(7,22,33,.96), rgba(7,22,33,.35)); }
    .review-grid { display: flex; gap: 1rem; overflow-x: auto; margin-right: -16px; padding: 0 16px .8rem 0; scroll-snap-type: x mandatory; scrollbar-width: none; overscroll-behavior-inline: contain; }
    .review-grid::-webkit-scrollbar { display: none; }
    .review-card { min-width: min(84vw, 370px); min-height: 340px; scroll-snap-align: start; scroll-snap-stop: always; }
