---
import Layout from '../layouts/Layout.astro';
import { blogPosts, plans, promoBenefits, services, testimonials, whatsappLink } from '../data/site';
---

<Layout title="Beranda" description="Internet fiber optic unlimited tanpa FUP, gratis pemasangan, dan layanan teknisi lokal dari BINNET. Paket promo mulai Rp149 ribu per bulan.">
  <section class="home-hero">
    <div class="hero-orbit orbit-one"></div>
    <div class="hero-orbit orbit-two"></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Fiber lokal · sejak 2013</p>
        <h1 class="display" data-split>Internet cepat itu harus <em>terasa.</em></h1>
        <div class="hero-bottom">
          <p>Fiber optic unlimited tanpa FUP. Jernih untuk meeting, mulus untuk streaming, dan siap saat seluruh rumah online bersamaan.</p>
          <div class="hero-actions">
            <a class="button" href={whatsappLink()} target="_blank" rel="noopener">Cek jaringan rumah</a>
            <a class="button button-ghost" href="#promo">Promo mulai Rp149 ribu</a>
          </div>
        </div>
      </div>

      <div class="hero-media reveal-media" data-parallax data-parallax-scroll data-speed=".035">
        <img src="/media/6060-img_5323.jpg" alt="Teknisi BINNET memasang jaringan fiber optic" width="1440" height="2560" fetchpriority="high" />
        <div class="media-note"><span>01</span><p>Tim lokal.<br />Respons lebih dekat.</p></div>
        <div class="live-pill"><i></i> Jaringan aktif</div>
      </div>
    </div>
    <div class="hero-index container"><span>PT Citra Bintang Net</span><span>Unlimited · Tanpa FUP · Gratis instalasi</span></div>
  </section>

  <div class="signal-ticker" aria-hidden="true">
    <div class="ticker-track">
      <span>Kerja tanpa jeda</span><i></i><span>Main tanpa drama</span><i></i><span>Nonton tanpa lingkaran</span><i></i><span>Harga tanpa kejutan</span><i></i>
      <span>Kerja tanpa jeda</span><i></i><span>Main tanpa drama</span><i></i><span>Nonton tanpa lingkaran</span><i></i><span>Harga tanpa kejutan</span><i></i>
    </div>
  </div>

  <section class="promo-stage" id="promo">
    <div class="promo-glow" data-parallax-scroll data-speed=".12"></div>
    <div class="container promo-shell">
      <div class="promo-heading reveal">
        <p class="eyebrow">Special promo · koneksi cepat, harga hemat</p>
        <h2 class="section-title" data-split>Lebih kencang.<br />Lebih masuk akal.</h2>
        <p class="lead">Empat paket baru dengan instalasi gratis, perangkat termasuk, customer service 24 jam, dan teknisi standby per area.</p>
      </div>

      <div class="promo-layout">
        <button class="promo-flyer reveal-media" id="promo-open" type="button" data-cursor data-parallax-scroll data-speed=".045" aria-label="Buka flyer promo BINNET">
          <img src="/media/generated/promo-binnet-special.webp" alt="Flyer special promo BINNET" width="1024" height="1536" />
          <span>Lihat flyer penuh <i>↗</i></span>
        </button>

        <div class="promo-content">
          <div class="promo-plans">
            {plans.map((plan, index) => (
              <article class:list={['promo-plan reveal', { hot: plan.recommended }]} data-magnetic>
                <div><span>{String(index + 1).padStart(2, '0')}</span><b>{plan.name}</b></div>
                <p><strong>{plan.speed}</strong> Mbps</p>
                <s>Rp{plan.oldPrice}.000</s>
                <h3><small>Rp</small>{plan.price}.000</h3>
                <a href={whatsappLink(`Halo BINNET, saya tertarik promo ${plan.name} ${plan.speed} Mbps seharga Rp${plan.price}.000. Mohon cek area saya.`)} target="_blank" rel="noopener" aria-label={`Pilih ${plan.name}`}>Pilih ↗</a>
              </article>
            ))}
          </div>
          <div class="promo-benefits reveal">
            {promoBenefits.map(item => <span><i>✓</i>{item}</span>)}
          </div>
          <div class="promo-cta reveal">
            <div><span>Bonus utama</span><strong>Tagihan paket promo flat*</strong></div>
            <a class="button" href={whatsappLink('Halo BINNET, saya ingin daftar special promo dan cek jaringan di alamat saya.')} target="_blank" rel="noopener">Ambil promo</a>
          </div>
          <p class="promo-terms">*Harga promo dan fasilitas mengikuti hasil pengecekan area serta syarat dan ketentuan BINNET.</p>
        </div>
      </div>
    </div>
  </section>

  <dialog class="promo-modal" id="promo-modal">
    <button type="button" id="promo-close" aria-label="Tutup flyer">×</button>
    <img src="/media/generated/promo-binnet-special.webp" alt="Flyer lengkap special promo BINNET" width="1024" height="1536" />
  </dialog>

  <section class="section manifesto">
    <div class="container manifesto-grid">
      <div class="manifesto-number reveal">13<span>+</span></div>
      <div class="reveal">
        <p class="eyebrow">Lebih dari koneksi</p>
        <h2 class="section-title" data-split>Internet rumah bukan soal angka paling besar.</h2>
        <p class="lead manifesto-lead">Yang penting adalah stabil saat dibutuhkan, jelas tagihannya, dan ada manusia yang merespons ketika sesuatu tidak berjalan semestinya. Itulah cara BINNET bekerja sejak 2013.</p>
      </div>
    </div>
  </section>

  <section class="section package-section" id="paket">
    <div class="container">
      <div class="package-head reveal">
        <div>
          <p class="eyebrow">Pilih ritme rumah Anda</p>
          <h2 class="section-title" data-split>Kecepatan yang pas.<br />Bukan asal tinggi.</h2>
        </div>
        <p class="lead">Semua paket unlimited tanpa FUP, sudah termasuk PPN, perangkat, dan pemasangan.</p>
      </div>

      <div class="plans">
        {plans.map((plan, index) => (
          <article class:list={['plan reveal', { recommended: plan.recommended }]} style={`--delay:${index * 60}ms`}>
            <div class="plan-top"><span>{String(index + 1).padStart(2, '0')}</span><b>{plan.name}</b></div>
            <div class="plan-speed"><strong>{plan.speed}</strong><span>Mbps</span></div>
            <p class="plan-fit">{plan.fit}</p>
            <div class="plan-price"><small>Rp</small><strong>{plan.price}k</strong><span>/bulan</span></div>
            <s>Normal Rp{plan.oldPrice}k</s>
            <div class="plan-device">Ideal untuk <b>{plan.devices}</b></div>
            <a href={whatsappLink(`Halo BINNET, saya tertarik paket ${plan.speed} Mbps. Bisa cek jaringan di alamat saya?`)} target="_blank" rel="noopener">Pilih paket <span>↗</span></a>
          </article>
        ))}
      </div>
      <p class="package-note">*Ketersediaan layanan mengikuti hasil pengecekan jaringan di alamat pemasangan.</p>
    </div>
  </section>

  <section class="section service-section">
    <div class="container">
      <div class="service-intro reveal">
        <p class="eyebrow">Satu tim, tiga solusi</p>
        <h2 class="section-title" data-split>Rumah terhubung.<br />Rumah terlindungi.</h2>
      </div>
      <div class="service-list">
        {services.map(service => (
          <a class="service-row reveal" href="/our-services">
            <span class="service-num">{service.number}</span>
            <div class="service-image"><img src={service.image} alt="" loading="lazy" /></div>
            <h3>{service.title}</h3>
            <p>{service.description}</p>
            <span class="service-arrow">↗</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="field-story">
    <div class="field-image" data-parallax-scroll data-speed=".04"><img src="/media/6058-img_5315.jpg" alt="Tim teknisi BINNET" width="2560" height="1440" loading="lazy" /></div>
    <div class="field-copy reveal">
      <p class="eyebrow">Bukan call center anonim</p>
      <h2 data-split>Tim yang tahu jalan menuju rumah Anda.</h2>
      <p>BINNET dibangun sebagai jaringan lokal. Artinya, komunikasi lebih dekat, konteks area lebih dipahami, dan penanganan tidak berhenti di nomor tiket.</p>
      <a class="button" href="/about-us">Kenal BINNET</a>
    </div>
    <div class="field-caption"><span>Tim operasional BINNET</span><span>Depok dan sekitarnya</span></div>
  </section>

  <section class="section review-section">
    <div class="container">
      <div class="review-head reveal">
        <div><p class="eyebrow">Cerita dari jaringan</p><h2 class="section-title" data-split>Yang paling jujur adalah pengalaman pelanggan.</h2></div>
        <span class="quote-mark">“</span>
      </div>
      <div class="review-grid">
        {testimonials.map((item, index) => (
          <blockquote class="review-card reveal">
            <span class="review-index">{String(index + 1).padStart(2, '0')}</span>
            <p>“{item.quote}”</p>
            <footer><strong>{item.name}</strong><span>{item.area}</span></footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <section class="section journal-section">
    <div class="container">
      <div class="journal-head reveal">
        <div><p class="eyebrow">Jurnal koneksi</p><h2 class="section-title" data-split>Biar teknologi tidak terasa teknis.</h2></div>
        <a href="/blog">Lihat semua artikel <span>↗</span></a>
      </div>
      <div class="journal-grid">
        {blogPosts.slice(0, 3).map((post, index) => (
          <a class:list={['journal-card reveal', { featured: index === 0 }]} href={`/blog/${post.slug}`}>
            <div class="journal-image"><img src={post.image} alt="" loading="lazy" /></div>
            <div class="journal-meta"><span>{post.category}</span><span>{post.readTime}</span></div>
            <h3>{post.title}</h3>
            <p>{post.excerpt}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .home-hero { position: relative; overflow: hidden; min-height: 100svh; padding: 10rem 0 2rem; background: var(--ink); color: var(--white); }
  .hero-grid { position: relative; z-index: 2; display: grid; min-height: calc(100svh - 12rem); grid-template-columns: minmax(0, 1.45fr) minmax(300px, .55fr); gap: 3.5rem; align-items: center; }
  .hero-copy { padding-bottom: 4rem; }
  .hero-copy .eyebrow { color: var(--lime); }
  .hero-copy h1 { max-width: 990px; }
  .hero-copy h1 em { color: var(--cyan); font-style: normal; }
  .hero-bottom { display: grid; max-width: 950px; grid-template-columns: 1fr auto; gap: 2rem; align-items: end; margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,.18); }
  .hero-bottom > p { max-width: 560px; color: rgba(255,255,255,.64); font-size: clamp(.96rem, 1.3vw, 1.12rem); }
  .hero-actions { display: flex; gap: .75rem; flex-wrap: wrap; }
  .hero-media { position: relative; align-self: stretch; min-height: 580px; overflow: hidden; border-radius: 180px 180px 28px 28px; transform: rotate(2deg); box-shadow: 0 30px 80px rgba(0,0,0,.3); }
  .hero-media::after { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 50%, rgba(7,22,33,.85)); content: ''; }
  .hero-media img { width: 100%; height: 100%; object-fit: cover; }
  .media-note { position: absolute; z-index: 2; right: 1rem; bottom: 1rem; left: 1rem; display: flex; justify-content: space-between; gap: 1rem; padding: 1.2rem; border: 1px solid rgba(255,255,255,.18); border-radius: 18px; background: rgba(7,22,33,.58); backdrop-filter: blur(14px); }
  .media-note span { color: var(--lime); font-size: .7rem; }
  .media-note p { font-family: 'Space Grotesk'; font-size: 1rem; font-weight: 600; line-height: 1.2; }
  .live-pill { position: absolute; z-index: 3; top: 35%; left: -5px; display: flex; align-items: center; gap: .6rem; padding: .6rem .85rem; border-radius: 999px; background: var(--white); color: var(--ink); font-size: .66rem; font-weight: 800; transform: rotate(-2deg); }
  .live-pill i { width: 8px; height: 8px; border-radius: 50%; background: var(--lime); box-shadow: 0 0 0 5px rgba(167,237,82,.2); }
  .hero-orbit { position: absolute; z-index: 1; border: 1px solid rgba(53,198,244,.18); border-radius: 50%; }
  .orbit-one { top: 0; right: -15vw; width: 70vw; aspect-ratio: 1; }
  .orbit-two { right: 13vw; bottom: -30vw; width: 48vw; aspect-ratio: 1; border-color: rgba(167,237,82,.18); }
  .hero-index { position: relative; z-index: 3; display: flex; justify-content: space-between; gap: 1rem; padding-top: 1.25rem; border-top: 1px solid rgba(255,255,255,.12); color: rgba(255,255,255,.38); font-size: .64rem; letter-spacing: .11em; text-transform: uppercase; }

  .signal-ticker { overflow: hidden; padding: 1.1rem 0; background: var(--lime); }
  .ticker-track { display: flex; width: max-content; align-items: center; gap: 1.7rem; animation: ticker 28s linear infinite; font-family: 'Space Grotesk'; font-size: 1rem; font-weight: 700; letter-spacing: -.02em; text-transform: uppercase; }
  .ticker-track i { width: 7px; height: 7px; border-radius: 50%; background: var(--ink); }
  @keyframes ticker { to { transform: translateX(-50%); } }

  .promo-stage { position: relative; overflow: hidden; padding: clamp(6rem, 11vw, 11rem) 0; background: #061d49; color: var(--white); }
  .promo-stage::before { position: absolute; inset: 0; background: radial-gradient(circle at 70% 15%, rgba(53,198,244,.22), transparent 34%), linear-gradient(135deg, rgba(10,63,191,.35), transparent 50%); content: ''; }
  .promo-glow { position: absolute; top: 10%; right: -10%; width: 48vw; aspect-ratio: 1; border: 1px solid rgba(255,255,255,.16); border-radius: 50%; box-shadow: 0 0 120px rgba(53,198,244,.12), inset 0 0 90px rgba(167,237,82,.06); }
  .promo-shell { position: relative; z-index: 1; }
  .promo-heading { display: grid; grid-template-columns: 1.15fr .85fr; gap: 2rem 5rem; align-items: end; margin-bottom: 4.5rem; }
  .promo-heading .eyebrow { grid-column: 1 / -1; color: var(--lime); }
  .promo-heading .lead { justify-self: end; color: rgba(255,255,255,.63); }
  .promo-layout { display: grid; grid-template-columns: minmax(300px, .7fr) minmax(0, 1.3fr); gap: clamp(2rem, 5vw, 5rem); align-items: start; }
  .promo-flyer { position: relative; top: 0; width: 100%; padding: 0; border: 1px solid rgba(255,255,255,.2); border-radius: 28px; background: none; box-shadow: 0 36px 90px rgba(0,0,0,.34); cursor: pointer; transform: rotate(-2deg); transition: transform .6s var(--ease), box-shadow .6s; }
  .promo-flyer:hover { transform: rotate(0) translateY(-8px); box-shadow: 0 48px 110px rgba(0,0,0,.45); }
  .promo-flyer img { width: 100%; border-radius: inherit; }
  .promo-flyer > span { position: absolute; right: 1rem; bottom: 1rem; left: 1rem; display: flex; justify-content: space-between; padding: .85rem 1rem; border: 1px solid rgba(255,255,255,.25); border-radius: 999px; background: rgba(7,22,33,.82); backdrop-filter: blur(14px); color: var(--white); font-size: .7rem; font-weight: 800; }
  .promo-flyer > span i { color: var(--lime); font-style: normal; }
  .promo-content { min-width: 0; }
  .promo-plans { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
  .promo-plan { min-height: 300px; display: flex; flex-direction: column; padding: 1.35rem; border: 1px solid rgba(255,255,255,.16); border-radius: 22px; background: rgba(255,255,255,.06); backdrop-filter: blur(12px); transition: background .4s, color .4s, border-color .4s; }
  .promo-plan:hover, .promo-plan.hot { border-color: var(--lime); background: var(--lime); color: var(--ink); }
  .promo-plan > div { display: flex; justify-content: space-between; gap: .6rem; color: rgba(255,255,255,.48); font-size: .6rem; letter-spacing: .08em; text-transform: uppercase; }
  .promo-plan.hot > div, .promo-plan:hover > div { color: rgba(7,22,33,.58); }
  .promo-plan > p { display: flex; align-items: baseline; gap: .45rem; margin: 2.3rem 0 0; }
  .promo-plan > p strong { font-family: 'Space Grotesk'; font-size: clamp(3.2rem, 5vw, 5.2rem); font-weight: 500; letter-spacing: -.08em; line-height: .7; }
  .promo-plan > p { font-size: .7rem; font-weight: 800; }
  .promo-plan > s { margin-top: 1rem; color: #ff716a; font-size: .65rem; }
  .promo-plan.hot > s, .promo-plan:hover > s { color: var(--red); }
  .promo-plan h3 { margin-top: auto; font-family: 'Space Grotesk'; font-size: 2rem; letter-spacing: -.05em; }
  .promo-plan h3 small { margin-right: .15rem; font-family: 'Manrope'; font-size: .65rem; }
  .promo-plan > a { display: flex; justify-content: space-between; margin-top: 1rem; padding-top: .8rem; border-top: 1px solid currentColor; font-size: .7rem; font-weight: 800; }
  .promo-benefits { display: flex; gap: .55rem; flex-wrap: wrap; margin-top: 1.3rem; }
  .promo-benefits span { display: inline-flex; align-items: center; gap: .5rem; padding: .6rem .75rem; border: 1px solid rgba(255,255,255,.18); border-radius: 999px; color: rgba(255,255,255,.7); font-size: .61rem; }
  .promo-benefits i { display: grid; width: 17px; height: 17px; place-items: center; border-radius: 50%; background: var(--lime); color: var(--ink); font-size: .55rem; font-style: normal; }
  .promo-cta { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; margin-top: 1.5rem; padding: 1rem 1rem 1rem 1.4rem; border-radius: 999px; background: var(--white); color: var(--ink); }
  .promo-cta > div { display: grid; }
  .promo-cta > div span { color: var(--red); font-size: .57rem; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; }
  .promo-cta > div strong { font-family: 'Space Grotesk'; font-size: 1rem; }
  .promo-terms { margin-top: .8rem; color: rgba(255,255,255,.38); font-size: .58rem; }
  .promo-modal { width: min(92vw, 650px); max-height: 92svh; padding: 0; overflow: visible; border: 0; border-radius: 24px; background: transparent; box-shadow: 0 36px 100px rgba(0,0,0,.5); }
  .promo-modal::backdrop { background: rgba(2,12,25,.84); backdrop-filter: blur(15px); }
  .promo-modal img { width: 100%; max-height: 90svh; object-fit: contain; border-radius: 20px; }
  .promo-modal button { position: absolute; z-index: 2; top: -18px; right: -18px; width: 44px; height: 44px; border: 0; border-radius: 50%; background: var(--lime); color: var(--ink); font-size: 1.5rem; cursor: pointer; }

  .manifesto { background: var(--paper); }
  .manifesto-grid { display: grid; grid-template-columns: .45fr 1.55fr; gap: clamp(2rem, 8vw, 9rem); align-items: start; }
  .manifesto-number { color: var(--cyan-deep); font-family: 'Space Grotesk'; font-size: clamp(6rem, 15vw, 13rem); font-weight: 600; letter-spacing: -.09em; line-height: .78; }
  .manifesto-number span { color: var(--lime); font-size: .35em; vertical-align: top; }
  .manifesto-lead { margin: 2.5rem 0 0 auto; }

  .package-section { background: var(--white); }
  .package-head { display: grid; grid-template-columns: 1.2fr .8fr; gap: 3rem; align-items: end; margin-bottom: 4.5rem; }
  .package-head .lead { justify-self: end; }
  .plans { display: grid; grid-template-columns: repeat(4, 1fr); border-top: 1px solid var(--line); border-left: 1px solid var(--line); }
  .plan { position: relative; min-height: 530px; display: flex; flex-direction: column; padding: 1.5rem; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); transition: background .45s var(--ease), color .45s, transform .45s var(--ease); transition-delay: var(--delay); }
  .plan:hover, .plan.recommended { z-index: 2; background: var(--ink); color: var(--white); transform: translateY(-12px); }
  .plan-top { min-height: 28px; display: flex; justify-content: space-between; gap: .5rem; color: var(--muted); font-size: .64rem; letter-spacing: .1em; text-transform: uppercase; }
  .plan-top b { color: var(--lime); font-size: .58rem; }
  .plan-speed { display: flex; align-items: baseline; gap: .45rem; margin: 2.7rem 0 1.1rem; }
  .plan-speed strong { font-family: 'Space Grotesk'; font-size: clamp(3.8rem, 5.3vw, 5.8rem); font-weight: 500; letter-spacing: -.08em; line-height: .75; }
  .plan-speed span { font-size: .7rem; font-weight: 800; text-transform: uppercase; }
  .plan-fit { min-height: 64px; color: var(--muted); font-size: .78rem; }
  .plan:hover .plan-fit, .plan.recommended .plan-fit, .plan:hover .plan-top, .plan.recommended .plan-top { color: rgba(255,255,255,.56); }
  .plan-price { display: flex; align-items: baseline; gap: .25rem; margin-top: auto; }
  .plan-price small { font-size: .68rem; font-weight: 800; }
  .plan-price strong { font-family: 'Space Grotesk'; font-size: 2.5rem; letter-spacing: -.05em; }
  .plan-price span { color: var(--muted); font-size: .66rem; }
  .plan s { color: var(--red); font-size: .65rem; }
  .plan-device { margin: 1.3rem 0; padding-top: 1rem; border-top: 1px solid var(--line); color: var(--muted); font-size: .7rem; }
  .plan:hover .plan-device, .plan.recommended .plan-device { border-color: rgba(255,255,255,.15); color: rgba(255,255,255,.55); }
  .plan-device b { display: block; color: inherit; }
  .plan > a { display: flex; justify-content: space-between; padding-top: 1rem; border-top: 1px solid currentColor; font-size: .72rem; font-weight: 800; }
  .plan > a span { color: var(--cyan); font-size: 1rem; }
  .package-note { margin-top: 1rem; color: var(--muted); font-size: .67rem; }

  .service-section { background: var(--paper); }
  .service-intro { margin-bottom: 4rem; }
  .service-list { border-top: 1px solid var(--line); }
  .service-row { display: grid; grid-template-columns: 55px 120px .85fr 1fr 40px; gap: 2rem; align-items: center; min-height: 170px; padding: 1.2rem 0; border-bottom: 1px solid var(--line); transition: padding .45s var(--ease), color .3s; }
  .service-row:hover { padding-inline: 1rem; color: var(--cyan-deep); }
  .service-num { color: var(--muted); font-size: .66rem; }
  .service-image { width: 120px; height: 120px; overflow: hidden; border-radius: 50%; }
  .service-image img { width: 100%; height: 100%; object-fit: cover; transition: transform .7s var(--ease); }
  .service-row:hover img { transform: scale(1.1); }
  .service-row h3 { font-family: 'Space Grotesk'; font-size: clamp(1.7rem, 3vw, 3.2rem); font-weight: 600; letter-spacing: -.05em; }
  .service-row p { color: var(--muted); font-size: .84rem; }
