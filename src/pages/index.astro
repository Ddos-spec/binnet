---
import Layout from '../layouts/Layout.astro';
import ResponsiveImage from '../components/ResponsiveImage.astro';
import { blogPosts, plans, promoBenefits, services, testimonials, whatsappLink } from '../data/site';

const imageId = (path: string) => path.replace('/media/', '').replace(/\.[^.]+$/, '');
const imageDimensions: Record<string, [number, number]> = {
  '/media/6060-img_5323.jpg': [1440, 2560],
  '/media/6063-img-20250408-wa0013.jpg': [1920, 2560],
};
---

<Layout title="Beranda" description="Internet fiber optic unlimited untuk rumah dan usaha dari BINNET. Paket mulai Rp149 ribu per bulan.">
  <section class="home-hero">
    <div class="hero-orbit orbit-one"></div>
    <div class="hero-orbit orbit-two"></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Koneksi Cepat, Harga Hemat</p>
        <h1 class="display" data-split>Internet cepat itu harus <em>terasa.</em></h1>
        <div class="hero-bottom">
          <p>Fiber optic unlimited tanpa FUP. Jernih untuk meeting, mulus untuk streaming, dan siap saat seluruh rumah online bersamaan.</p>
          <div class="hero-actions">
            <a class="button" href={whatsappLink()} target="_blank" rel="noopener">Cek ketersediaan area</a>
            <a class="button button-ghost" href="#kenapa-binnet">Kenapa BINNET</a>
          </div>
        </div>
      </div>

      <div class="hero-media reveal-media" data-parallax data-parallax-scroll data-speed=".035">
        <ResponsiveImage id="6060-img_5323" alt="Teknisi BINNET memasang jaringan fiber optic" width={1440} height={2560} sizes="(max-width: 960px) calc(100vw - 48px), 38vw" loading="eager" fetchpriority="high" position="center top" />
        <div class="media-note"><span>01</span><p>Tim lokal.<br />Respons lebih dekat.</p></div>
        <div class="live-pill"><i></i> Jaringan aktif</div>
      </div>
    </div>
    <div class="hero-index container"><span>PT Citra Bintang Net</span><span>Unlimited · Tanpa FUP · Gratis instalasi</span></div>
  </section>

  <div class="signal-ticker" aria-hidden="true">
    <div class="ticker-track">
      <span>Kerja tanpa jeda</span><i></i><span>Main tanpa drama</span><i></i><span>Nonton tanpa lingkaran</span><i></i><span>Harga tanpa kejutan</span><i></i>
      <span>Kerja tanpa jeda</span><i></i><span>Main tanpa drama</span><i></i><span>Nonton tanpa lingkaran</span><i></i><span>Harga tanpa kejutan</span><i></i>
    </div>
  </div>

  <section class="trust-section" id="kenapa-binnet" aria-labelledby="trust-title">
    <div class="container">
      <div class="trust-heading reveal">
        <p class="eyebrow">Alasan untuk percaya</p>
        <h2 id="trust-title">Hal penting yang kami jelaskan sejak awal.</h2>
      </div>
      <div class="trust-track" aria-label="Keunggulan layanan BINNET">
        <article class="trust-card reveal"><span>01</span><strong>Unlimited tanpa FUP</strong><p>Pakai koneksi tanpa batas kuota bulanan.</p></article>
        <article class="trust-card reveal"><span>02</span><strong>Harga transparan</strong><p>Biaya dijelaskan sebelum proses pemasangan.</p></article>
        <article class="trust-card reveal"><span>03</span><strong>Customer service 24 jam</strong><p>Satu pintu komunikasi saat Anda butuh bantuan.</p></article>
        <article class="trust-card reveal"><span>04</span><strong>Teknisi sesuai area</strong><p>Penanganan menyesuaikan kondisi di lapangan.</p></article>
      </div>
      <p class="swipe-hint">Geser untuk melihat alasan lainnya <span>→</span></p>
    </div>
  </section>

  <dialog class="welcome-promo" id="welcome-promo" aria-labelledby="welcome-promo-title">
    <div class="welcome-promo-card">
      <header>
        <div>
          <span>Special promo BINNET</span>
          <strong id="welcome-promo-title">Koneksi Cepat, Harga Hemat</strong>
        </div>
        <button type="button" id="welcome-promo-close" aria-label="Tutup informasi promo">×</button>
      </header>
      <img
        data-src="/media/promo-special-2026.webp"
        data-srcset="/media/promo-special-2026-540.webp 540w, /media/promo-special-2026.webp 1024w"
        data-sizes="(max-width: 560px) calc(100vw - 24px), 430px"
        alt="Brosur paket promo BINNET 25, 50, 80, dan 100 Mbps"
        width="1024"
        height="1536"
        decoding="async"
        fetchpriority="low"
      />
      <footer>
        <p>Mulai <strong>Rp149.000/bulan</strong><small>Ketersediaan mengikuti hasil pengecekan area.</small></p>
        <a href={whatsappLink('Halo BINNET, saya melihat promo di website dan ingin mengecek jaringan di alamat saya.')} target="_blank" rel="noopener">Cek area <span>↗</span></a>
      </footer>
    </div>
  </dialog>

  <section class="section manifesto">
    <div class="container manifesto-grid">
      <div class="manifesto-number reveal">∞</div>
      <div class="reveal">
        <p class="eyebrow">Mulai dari kebutuhan, bukan angka</p>
        <h2 class="section-title" data-split>Internet yang baik terasa saat semua tetap berjalan.</h2>
        <p class="lead manifesto-lead">Meeting tetap jernih, belajar tidak terputus, dan hiburan tidak menunggu buffering. Kecepatan berarti ketika seluruh rumah bisa memakainya dengan tenang.</p>
      </div>
    </div>
  </section>

  <section class="section service-section">
    <div class="container">
      <div class="service-intro reveal">
        <p class="eyebrow">Satu kebutuhan, solusi yang jelas</p>
        <h2 class="section-title" data-split>Rumah terhubung.<br />Rumah terlindungi.</h2>
      </div>
      <div class="service-list">
        {services.map(service => (
          <a class="service-row reveal" href="/our-services">
            <span class="service-num">{service.number}</span>
            <div class="service-image">
              {imageDimensions[service.image]
                ? <ResponsiveImage id={imageId(service.image)} alt="" width={imageDimensions[service.image][0]} height={imageDimensions[service.image][1]} sizes="(max-width: 780px) 75px, 120px" />
                : <img src={service.image} alt="" width="626" height="417" loading="lazy" decoding="async" />}
            </div>
            <h3>{service.title}</h3>
            <p>{service.description}</p>
            <span class="service-arrow">↗</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="field-story">
    <div class="field-image" data-parallax-scroll data-speed=".04"><ResponsiveImage id="6058-img_5315" alt="Tim teknisi BINNET" width={2560} height={1440} sizes="100vw" /></div>
    <div class="field-copy reveal">
      <p class="eyebrow">Bukti operasional</p>
      <h2 data-split>Tim yang tahu jalan menuju rumah Anda.</h2>
      <p>BINNET hadir dengan proses layanan yang jelas, komunikasi yang mudah dihubungi, dan penanganan yang terukur untuk setiap kebutuhan koneksi.</p>
      <a class="button" href="/about-us">Kenal BINNET</a>
    </div>
    <div class="field-caption"><span>Tim operasional BINNET</span><span>Area layanan BINNET</span></div>
  </section>

  <section class="section review-section">
    <div class="container">
      <div class="review-head reveal">
        <div><p class="eyebrow">Cerita dari jaringan</p><h2 class="section-title" data-split>Yang paling jujur adalah pengalaman pelanggan.</h2></div>
        <span class="quote-mark">“</span>
      </div>
      <div class="review-grid" id="home-reviews" tabindex="0" aria-label="Testimoni pelanggan BINNET" data-review-slider>
        {testimonials.map((item, index) => (
          <blockquote class="review-card reveal" data-review-card>
            <span class="review-index">{String(index + 1).padStart(2, '0')}</span>
            <p>“{item.quote}”</p>
            <footer><strong>{item.name}</strong><span>{item.profession}</span></footer>
          </blockquote>
        ))}
      </div>
      <div class="review-controls" aria-label="Navigasi testimoni">
        <button type="button" data-review-prev aria-label="Testimoni sebelumnya">←</button>
        <div class="review-dots">
          {testimonials.map((_, index) => <button type="button" class:list={{ active: index === 0 }} data-review-dot={index} aria-label={`Lihat testimoni ${index + 1}`}></button>)}
        </div>
        <button type="button" data-review-next aria-label="Testimoni berikutnya">→</button>
      </div>
    </div>
  </section>

  <section class="promo-stage" id="promo">
    <div class="promo-glow" data-parallax-scroll data-speed=".12"></div>
    <div class="container promo-shell">
      <div class="promo-heading reveal">
        <p class="eyebrow">Pilih setelah yakin</p>
        <h2 class="section-title" data-split>Sekarang, pilih ritme yang pas.</h2>
        <p class="lead">Mulai dari jumlah perangkat dan aktivitas yang berjalan bersamaan. Semua paket unlimited tanpa FUP, dengan biaya yang dijelaskan sebelum pemasangan.</p>
      </div>

      <div class="promo-layout">
        <div class="promo-content">
          <div class="promo-plans">
            {plans.map((plan, index) => (
              <article class:list={['promo-plan reveal', { hot: plan.recommended }]} data-magnetic>
                <div><span>{String(index + 1).padStart(2, '0')}</span><b>{plan.name}</b></div>
                <p><strong>{plan.speed}</strong> Mbps</p>
                <span class="plan-fit-copy">{plan.fit} · {plan.devices}</span>
                <s>Harga normal Rp{plan.oldPrice}.000</s>
                <h3><small>Rp</small>{plan.price}.000</h3>
                <a href={whatsappLink(`Halo BINNET, saya tertarik promo ${plan.name} ${plan.speed} Mbps seharga Rp${plan.price}.000. Mohon cek area saya.`)} target="_blank" rel="noopener" aria-label={`Pilih ${plan.name}`}>Pilih paket <span>↗</span></a>
              </article>
            ))}
          </div>
          <div class="promo-benefits reveal">
            {promoBenefits.map(item => <span><i>✓</i>{item}</span>)}
          </div>
          <div class="promo-cta reveal">
            <div><span>Langkah berikutnya</span><strong>Cek jaringan di alamat Anda</strong></div>
            <a class="button" href={whatsappLink('Halo BINNET, saya ingin daftar special promo dan cek jaringan di alamat saya.')} target="_blank" rel="noopener">Cek area &amp; daftar</a>
          </div>
          <p class="promo-terms">*Harga promo dan fasilitas mengikuti hasil pengecekan area serta syarat dan ketentuan BINNET.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section journal-section">
    <div class="container">
      <div class="journal-head reveal">
        <div><p class="eyebrow">Jurnal koneksi</p><h2 class="section-title" data-split>Biar teknologi tidak terasa teknis.</h2></div>
        <a href="/blog">Lihat semua artikel <span>↗</span></a>
      </div>
      <div class="journal-grid">
        {blogPosts.slice(0, 3).map((post, index) => (
          <a class:list={['journal-card reveal', { featured: index === 0 }]} href={`/blog/${post.slug}`}>
            <div class="journal-image"><img src={post.image} alt="" loading="lazy" /></div>
            <div class="journal-meta"><span>{post.category}</span><span>{post.readTime}</span></div>
            <h3>{post.title}</h3>
            <p>{post.excerpt}</p>
          </a>
        ))}
      </div>
      <p class="swipe-hint journal-swipe-hint">Geser untuk membaca artikel lainnya <span>→</span></p>
    </div>
  </section>
</Layout>

<style>
  .home-hero { position: relative; overflow: hidden; min-height: 100svh; padding: 10rem 0 2rem; background: var(--ink); color: var(--white); }
  .hero-grid { position: relative; z-index: 2; display: grid; min-height: calc(100svh - 12rem); grid-template-columns: minmax(0, 1.45fr) minmax(300px, .55fr); gap: 3.5rem; align-items: center; }
  .hero-copy { padding-bottom: 4rem; }
  .hero-copy .eyebrow { color: var(--lime); }
  .hero-copy h1 { max-width: 990px; }
  .hero-copy h1 em { color: var(--cyan); font-style: normal; }
  .hero-bottom { display: grid; max-width: 950px; grid-template-columns: 1fr auto; gap: 2rem; align-items: end; margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,.18); }
  .hero-bottom > p { max-width: 560px; color: rgba(255,255,255,.64); font-size: clamp(.96rem, 1.3vw, 1.12rem); }
  .hero-actions { display: flex; gap: .75rem; flex-wrap: wrap; }
  .hero-media { position: relative; align-self: stretch; min-height: 580px; overflow: hidden; border-radius: 180px 180px 28px 28px; transform: rotate(2deg); box-shadow: 0 30px 80px rgba(0,0,0,.3); }
  .hero-media::after { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 50%, rgba(7,22,33,.85)); content: ''; }
  .hero-media img { width: 100%; height: 100%; object-fit: cover; }
  .media-note { position: absolute; z-index: 2; right: 1rem; bottom: 1rem; left: 1rem; display: flex; justify-content: space-between; gap: 1rem; padding: 1.2rem; border: 1px solid rgba(255,255,255,.18); border-radius: 18px; background: rgba(7,22,33,.58); backdrop-filter: blur(14px); }
  .media-note span { color: var(--lime); font-size: .7rem; }
  .media-note p { font-family: 'Space Grotesk'; font-size: 1rem; font-weight: 600; line-height: 1.2; }
  .live-pill { position: absolute; z-index: 3; top: 35%; left: -5px; display: flex; align-items: center; gap: .6rem; padding: .6rem .85rem; border-radius: 999px; background: var(--white); color: var(--ink); font-size: .66rem; font-weight: 800; transform: rotate(-2deg); }
  .live-pill i { width: 8px; height: 8px; border-radius: 50%; background: var(--lime); box-shadow: 0 0 0 5px rgba(167,237,82,.2); }
  .hero-orbit { position: absolute; z-index: 1; border: 1px solid rgba(53,198,244,.18); border-radius: 50%; }
  .orbit-one { top: 0; right: -15vw; width: 70vw; aspect-ratio: 1; }
  .orbit-two { right: 13vw; bottom: -30vw; width: 48vw; aspect-ratio: 1; border-color: rgba(167,237,82,.18); }
  .hero-index { position: relative; z-index: 3; display: flex; justify-content: space-between; gap: 1rem; padding-top: 1.25rem; border-top: 1px solid rgba(255,255,255,.12); color: rgba(255,255,255,.38); font-size: .64rem; letter-spacing: .11em; text-transform: uppercase; }

  .signal-ticker { overflow: hidden; padding: 1.1rem 0; background: var(--lime); }
  .ticker-track { display: flex; width: max-content; align-items: center; gap: 1.7rem; animation: ticker 28s linear infinite; font-family: 'Space Grotesk'; font-size: 1rem; font-weight: 700; letter-spacing: -.02em; text-transform: uppercase; }
  .ticker-track i { width: 7px; height: 7px; border-radius: 50%; background: var(--ink); }
  @keyframes ticker { to { transform: translateX(-50%); } }

  .trust-section { padding: clamp(5rem, 8vw, 8rem) 0; background: var(--white); }
  .trust-heading { display: grid; max-width: 760px; gap: 1.2rem; margin-bottom: 3.2rem; }
  .trust-heading h2 { font-family: 'Space Grotesk'; font-size: clamp(2.3rem, 4.6vw, 4.8rem); font-weight: 600; letter-spacing: -.055em; line-height: 1; }
  .trust-track { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); border-top: 1px solid var(--line); border-left: 1px solid var(--line); }
  .trust-card { min-height: 245px; display: flex; flex-direction: column; padding: 1.4rem; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); background: var(--white); }
  .trust-card > span { color: var(--cyan-deep); font-size: .76rem; font-weight: 800; }
  .trust-card strong { max-width: 250px; margin-top: auto; font-family: 'Space Grotesk'; font-size: clamp(1.35rem, 2vw, 1.8rem); letter-spacing: -.035em; line-height: 1.08; }
  .trust-card p { margin-top: .8rem; color: #46617f; font-size: .88rem; line-height: 1.65; }
  .swipe-hint { display: none; align-items: center; justify-content: space-between; margin-top: 1rem; color: #46617f; font-size: .78rem; font-weight: 700; }
  .swipe-hint span { color: var(--cyan-deep); font-size: 1.1rem; }

  .promo-stage { position: relative; overflow: hidden; padding: clamp(6rem, 11vw, 11rem) 0; background: #061d49; color: var(--white); }
  .promo-stage::before { position: absolute; inset: 0; background: radial-gradient(circle at 70% 15%, rgba(53,198,244,.22), transparent 34%), linear-gradient(135deg, rgba(10,63,191,.35), transparent 50%); content: ''; }
  .promo-glow { position: absolute; top: 10%; right: -10%; width: 48vw; aspect-ratio: 1; border: 1px solid rgba(255,255,255,.16); border-radius: 50%; box-shadow: 0 0 120px rgba(53,198,244,.12), inset 0 0 90px rgba(167,237,82,.06); }
  .promo-shell { position: relative; z-index: 1; }
  .promo-heading { display: grid; grid-template-columns: 1.15fr .85fr; gap: 2rem 5rem; align-items: end; margin-bottom: 4.5rem; }
  .promo-heading .eyebrow { grid-column: 1 / -1; color: var(--lime); }
  .promo-heading .lead { justify-self: end; color: rgba(255,255,255,.63); }
  .promo-layout { display: block; }
  .promo-content { min-width: 0; }
  .promo-plans { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
  .promo-plan { min-height: 300px; display: flex; flex-direction: column; padding: 1.35rem; border: 1px solid rgba(255,255,255,.16); border-radius: 22px; background: rgba(255,255,255,.06); backdrop-filter: blur(12px); transition: background .4s, color .4s, border-color .4s; }
  .promo-plan:hover, .promo-plan.hot { border-color: var(--lime); background: var(--lime); color: var(--ink); }
  .promo-plan > div { display: flex; justify-content: space-between; gap: .6rem; color: rgba(255,255,255,.7); font-size: .72rem; letter-spacing: .08em; text-transform: uppercase; }
  .promo-plan.hot > div, .promo-plan:hover > div { color: rgba(7,22,33,.58); }
  .promo-plan > p { display: flex; align-items: baseline; gap: .45rem; margin: 2.3rem 0 0; }
  .promo-plan > p strong { font-family: 'Space Grotesk'; font-size: clamp(3.2rem, 5vw, 5.2rem); font-weight: 500; letter-spacing: -.08em; line-height: .7; }
  .promo-plan > p { font-size: .78rem; font-weight: 800; }
  .plan-fit-copy { margin-top: 1.4rem; color: rgba(255,255,255,.68); font-size: .78rem; line-height: 1.5; }
  .promo-plan.hot .plan-fit-copy, .promo-plan:hover .plan-fit-copy { color: rgba(7,22,33,.68); }
  .promo-plan > s { margin-top: .8rem; color: #ff8a84; font-size: .76rem; }
  .promo-plan.hot > s, .promo-plan:hover > s { color: var(--red); }
  .promo-plan h3 { margin-top: auto; font-family: 'Space Grotesk'; font-size: 2rem; letter-spacing: -.05em; }
  .promo-plan h3 small { margin-right: .15rem; font-family: 'Manrope'; font-size: .76rem; }
  .promo-plan > a { display: flex; justify-content: space-between; margin-top: 1rem; padding-top: .8rem; border-top: 1px solid currentColor; font-size: .78rem; font-weight: 800; }
  .promo-benefits { display: flex; gap: .55rem; flex-wrap: wrap; margin-top: 1.3rem; }
  .promo-benefits span { display: inline-flex; align-items: center; gap: .5rem; padding: .65rem .8rem; border: 1px solid rgba(255,255,255,.22); border-radius: 999px; color: rgba(255,255,255,.82); font-size: .74rem; }
  .promo-benefits i { display: grid; width: 17px; height: 17px; place-items: center; border-radius: 50%; background: var(--lime); color: var(--ink); font-size: .55rem; font-style: normal; }
  .promo-cta { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; margin-top: 1.5rem; padding: 1rem 1rem 1rem 1.4rem; border-radius: 999px; background: var(--white); color: var(--ink); }
  .promo-cta > div { display: grid; }
  .promo-cta > div span { color: var(--red); font-size: .7rem; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; }
  .promo-cta > div strong { font-family: 'Space Grotesk'; font-size: 1rem; }
  .promo-terms { margin-top: .8rem; color: rgba(255,255,255,.64); font-size: .72rem; }

  .welcome-promo { width: min(calc(100vw - 28px), 430px); max-height: calc(100svh - 28px); margin: auto; padding: 0; overflow: hidden; border: 1px solid rgba(255,255,255,.24); border-radius: 26px; background: var(--white); color: var(--ink); box-shadow: 0 38px 110px rgba(2,18,48,.55); opacity: 0; transform: translateY(22px) scale(.96); transition: opacity .35s ease, transform .55s var(--ease), display .35s allow-discrete, overlay .35s allow-discrete; }
  .welcome-promo[open] { opacity: 1; transform: none; }
  .welcome-promo::backdrop { background: rgba(4,28,72,.78); backdrop-filter: blur(12px); opacity: 0; transition: opacity .35s ease, display .35s allow-discrete, overlay .35s allow-discrete; }
  .welcome-promo[open]::backdrop { opacity: 1; }
  @starting-style {
    .welcome-promo[open] { opacity: 0; transform: translateY(22px) scale(.96); }
    .welcome-promo[open]::backdrop { opacity: 0; }
  }
  .welcome-promo-card { display: grid; max-height: calc(100svh - 28px); grid-template-rows: auto minmax(0, 1fr) auto; }
  .welcome-promo header, .welcome-promo footer { position: relative; z-index: 1; display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: .85rem 1rem; background: var(--white); }
  .welcome-promo header > div { display: grid; gap: .15rem; }
  .welcome-promo header span { color: var(--cyan-deep); font-size: .68rem; font-weight: 800; letter-spacing: .13em; text-transform: uppercase; }
  .welcome-promo header strong { font-family: 'Space Grotesk'; font-size: 1rem; letter-spacing: -.025em; }
  .welcome-promo header button { width: 38px; height: 38px; flex: 0 0 38px; border: 0; border-radius: 50%; background: var(--ink); color: var(--white); font-size: 1.35rem; line-height: 1; cursor: pointer; transition: background .25s, color .25s, transform .35s var(--ease); }
  .welcome-promo header button:hover { background: var(--lime); color: var(--ink); transform: rotate(90deg); }
  .welcome-promo > .welcome-promo-card > img { width: 100%; height: 100%; min-height: 0; object-fit: contain; background: #0644b5; }
  .welcome-promo footer p { display: grid; color: var(--muted); font-size: .74rem; line-height: 1.35; }
  .welcome-promo footer p strong { color: var(--ink); font-size: .88rem; }
  .welcome-promo footer p small { font-size: .66rem; }
