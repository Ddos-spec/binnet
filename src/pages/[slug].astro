---
import Layout from '../layouts/Layout.astro';
import { faqs, plans, services, testimonials, whatsappLink } from '../data/site';

const pageMeta = {
  'about-us': { title: 'Tentang BINNET', eyebrow: 'Tentang kami', headline: 'Koneksi yang dirancang lebih sederhana.', description: 'Mengenal PT Citra Bintang Net, penyedia layanan internet fiber optic untuk rumah dan usaha.' },
  'our-services': { title: 'Layanan', eyebrow: 'Koneksi Cepat, Harga Hemat', headline: 'Layanan untuk rumah yang terkoneksi.', description: 'Internet fiber optic, pemasangan CCTV, serta perbaikan elektronik dan jaringan dari BINNET.' },
  pricing: { title: 'Paket Internet', eyebrow: 'Special promo', headline: 'Lebih kencang. Lebih hemat.', description: 'Paket promo internet BINNET 25 hingga 100 Mbps, mulai Rp149 ribu, unlimited tanpa FUP dan gratis pemasangan.' },
  'coverage-area': { title: 'Cek Area', eyebrow: 'Satu langkah sebelum online', headline: 'Mari lihat apakah jaringan kami sudah dekat.', description: 'Cek ketersediaan jaringan internet fiber BINNET untuk alamat rumah atau usaha Anda.' },
  'contact-us': { title: 'Kontak', eyebrow: 'Bicara dengan manusia', headline: 'Pertanyaan Anda tidak masuk ke ruang hampa.', description: 'Hubungi BINNET melalui WhatsApp untuk pengecekan jaringan, pemilihan paket, dan dukungan pelanggan.' },
  faq: { title: 'FAQ', eyebrow: 'Jawaban tanpa berputar', headline: 'Hal yang paling sering ingin diketahui.', description: 'Jawaban atas pertanyaan umum seputar paket, pemasangan, perangkat, dan layanan internet BINNET.' },
  'our-projects': { title: 'Aktivitas Lapangan', eyebrow: 'Di balik koneksi', headline: 'Dari tiang jaringan sampai ruang keluarga.', description: 'Dokumentasi tim dan aktivitas lapangan PT Citra Bintang Net.' },
  testomonials: { title: 'Testimoni', eyebrow: 'Suara pelanggan', headline: 'Bukti koneksi terbaik datang dari rumah mereka.', description: 'Pengalaman pelanggan BINNET mengenai stabilitas jaringan dan respons tim.' },
};

export function getStaticPaths() {
  return [
    'about-us',
    'our-services',
    'pricing',
    'coverage-area',
    'contact-us',
    'faq',
    'our-projects',
    'testomonials',
    'blog-grid',
  ].map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
if (slug === 'blog-grid') return Astro.redirect('/blog', 301);
const page = pageMeta[slug as keyof typeof pageMeta];
if (!page) return Astro.redirect('/404');
---

<Layout title={page.title} description={page.description}>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">{page.eyebrow}</p>
      <h1 class="display" data-split>{page.headline}</h1>
      <p class="lead">{page.description}</p>
    </div>
  </section>

  {slug === 'about-us' && (
    <>
      <section class="section story-section">
        <div class="container split-story">
          <div class="story-sticky reveal"><p class="eyebrow">Tentang BINNET</p><h2 class="section-title" data-split>Koneksi yang siap membantu kebutuhan Anda.</h2></div>
          <div class="story-copy reveal">
            <p class="large-copy">BINNET hadir untuk membuat internet rumah terasa lebih sederhana: koneksi yang stabil, biaya yang jelas, dan tim yang bisa benar-benar dihubungi.</p>
            <p>PT Citra Bintang Net menyediakan internet fiber optic unlimited untuk pelanggan rumah dan usaha. Kami juga menangani pemasangan CCTV serta perbaikan elektronik dan jaringan.</p>
            <p>Pendekatan lokal membantu tim memahami kondisi area, pola kebutuhan pelanggan, dan pentingnya respons yang cepat ketika koneksi menjadi bagian dari kerja, sekolah, dan aktivitas keluarga.</p>
          </div>
        </div>
      </section>
      <section class="team-mosaic">
        <div class="mosaic-wide reveal-media"><img src="/media/6058-img_5315.jpg" alt="Tim teknisi BINNET" loading="lazy" /></div>
        <div class="mosaic-tall reveal-media"><img src="/media/6060-img_5323.jpg" alt="Pekerjaan instalasi jaringan BINNET" loading="lazy" /></div>
        <div class="mosaic-small reveal-media"><img src="/media/6059-img_5407.jpg" alt="Tim layanan pelanggan BINNET" loading="lazy" /></div>
        <div class="mosaic-note"><span>01</span><p>Layanan internet untuk rumah dan usaha.</p></div>
      </section>
      <section class="section values-section">
        <div class="container"><p class="eyebrow">Cara kami bekerja</p><div class="value-grid">
          <article class="reveal"><span>01</span><h3>Jelas dari awal</h3><p>Paket, fasilitas, dan proses pemasangan dijelaskan sebelum pelanggan mengambil keputusan.</p></article>
          <article class="reveal"><span>02</span><h3>Respons manusia</h3><p>Kendala ditangani dengan komunikasi yang mudah dipahami, bukan jawaban template tanpa konteks.</p></article>
          <article class="reveal"><span>03</span><h3>Dekat dengan area</h3><p>Pengetahuan lapangan membantu tim membuat diagnosis dan penanganan yang lebih relevan.</p></article>
        </div></div>
      </section>
    </>
  )}

  {slug === 'our-services' && (
    <>
      <section class="section service-detail-section"><div class="container service-detail-grid">
        {services.map(service => (
          <article class="service-detail reveal">
            <div class="service-detail-media reveal-media"><img src={service.image} alt={service.title} loading="lazy" /></div>
            <div class="service-detail-copy"><span>{service.number}</span><h2 data-split>{service.title}</h2><p>{service.description}</p>
              <ul>{service.number === '01' ? <><li>Unlimited tanpa FUP</li><li>Gratis pemasangan</li><li>Paket promo 25–100 Mbps</li></> : service.number === '02' ? <><li>Pantau dari smartphone</li><li>Penempatan kamera terukur</li><li>Instalasi rapi</li></> : <><li>Pemeriksaan langsung</li><li>Diagnosis perangkat</li><li>Penanganan praktis</li></>}</ul>
              <a href={whatsappLink(`Halo BINNET, saya ingin konsultasi mengenai layanan ${service.title}.`)} target="_blank" rel="noopener">Konsultasikan kebutuhan ↗</a>
            </div>
          </article>
        ))}
      </div></section>
    </>
  )}

  {slug === 'pricing' && (
    <>
      <section class="section pricing-page"><div class="container">
        <div class="pricing-feature reveal"><div><p class="eyebrow">Koneksi Cepat, Harga Hemat</p><h2 data-split>Informasi paket yang jelas sejak awal.</h2><p>Harga, fasilitas, instalasi, dan kebutuhan perangkat dijelaskan sebelum Anda memilih paket.</p></div></div>
        <div class="pricing-note reveal"><span>Semua paket</span><p>Unlimited tanpa FUP · PPN termasuk · Perangkat termasuk · Gratis pemasangan · Stabil 24/7</p></div>
        <div class="price-table">
          {plans.map((plan, index) => (
          <article class:list={['price-row reveal', { picked: plan.recommended }]}>
              <span class="price-index">{String(index + 1).padStart(2, '0')}</span>
              <div class="price-speed"><strong>{plan.speed}</strong><span>Mbps</span></div>
              <div class="price-use"><b>{plan.name}</b><span>{plan.fit} · {plan.devices}</span></div>
              <div class="price-value"><s>Rp{plan.oldPrice}k</s><strong>Rp{plan.price}k</strong><span>/bulan</span></div>
              <a href={whatsappLink(`Halo BINNET, saya tertarik paket ${plan.speed} Mbps. Mohon cek jaringan di alamat saya.`)} target="_blank" rel="noopener">Pilih ↗</a>
            </article>
          ))}
        </div>
        <p class="fine-print">Ketersediaan layanan, harga, dan fasilitas mengikuti hasil pengecekan jaringan serta ketentuan yang berlaku di alamat pemasangan.</p>
      </div></section>
      <section class="section package-help"><div class="container help-grid"><div><p class="eyebrow">Masih ragu?</p><h2 class="section-title" data-split>Jangan bayar bandwidth yang tidak terpakai.</h2></div><div><p class="lead">Ceritakan jumlah perangkat dan aktivitas harian di rumah. Tim kami akan membantu memilih paket yang masuk akal.</p><a class="button button-dark" href={whatsappLink('Halo BINNET, saya ingin dibantu memilih paket yang sesuai untuk rumah saya.')} target="_blank" rel="noopener">Bantu pilih paket</a></div></div></section>
    </>
  )}

  {slug === 'coverage-area' && (
    <section class="section coverage-section"><div class="container coverage-grid">
      <div class="coverage-copy reveal"><p class="eyebrow">Cek dalam satu chat</p><h2 class="section-title" data-split>Kirim alamat. Kami cek jalurnya.</h2><p class="lead">Ketersediaan fiber ditentukan oleh posisi jaringan terdekat dan kondisi teknis di lapangan. Isi data singkat berikut untuk memulai pengecekan melalui WhatsApp.</p><div class="coverage-badges"><span>Tanpa biaya pengecekan</span><span>Jawaban dari tim lokal</span><span>Tidak mengikat</span></div></div>
      <form class="coverage-form reveal" id="coverage-form">
        <label><span>Nama</span><input required name="name" autocomplete="name" placeholder="Nama Anda" /></label>
        <label><span>Nomor WhatsApp</span><input required name="phone" inputmode="tel" autocomplete="tel" placeholder="08xx xxxx xxxx" /></label>
        <label><span>Alamat pemasangan</span><textarea required name="address" rows="4" placeholder="Nama jalan, RT/RW, kelurahan, kecamatan"></textarea></label>
        <label><span>Patokan terdekat <i>opsional</i></span><input name="landmark" placeholder="Komplek, sekolah, masjid, atau toko" /></label>
        <button class="button button-dark" type="submit">Kirim untuk dicek</button>
        <small>Data hanya dipakai untuk membantu pengecekan jaringan melalui WhatsApp.</small>
      </form>
    </div></section>
  )}

  {slug === 'contact-us' && (
    <section class="section contact-section"><div class="container contact-grid">
      <div class="contact-primary reveal"><span class="contact-label">Customer service</span><a href={whatsappLink()} target="_blank" rel="noopener">0857<br />7385<br />4210 <i>↗</i></a></div>
      <div class="contact-secondary reveal"><div><span>Email</span><a href="mailto:customerservice@binnet.biz.id">customerservice@binnet.biz.id ↗</a></div><div><span>Kebutuhan</span><p>Cek area · Pendaftaran · Dukungan pelanggan · CCTV · Perbaikan jaringan</p></div><div><span>Sebelum menghubungi</span><p>Siapkan alamat lengkap, nomor pelanggan bila sudah berlangganan, serta foto indikator router jika ada kendala.</p></div></div>
    </div></section>
  )}

  {slug === 'faq' && (
    <section class="section faq-section"><div class="container faq-grid">
      <div class="faq-sticky reveal"><p class="eyebrow">Informasi dasar</p><h2 class="section-title" data-split>Singkat, jelas, selesai.</h2><a class="button button-dark" href={whatsappLink('Halo BINNET, saya punya pertanyaan mengenai layanan internet.')} target="_blank" rel="noopener">Tanya hal lain</a></div>
      <div class="faq-list">{faqs.map((item, index) => <details class="reveal"><summary><span>{String(index + 1).padStart(2, '0')}</span><b>{item.question}</b><i>+</i></summary><p>{item.answer}</p></details>)}</div>
    </div></section>
  )}

  {slug === 'our-projects' && (
    <section class="section gallery-section"><div class="container gallery-grid">
      {[
        ['/media/6060-img_5323.jpg', 'Instalasi jalur jaringan'], ['/media/6058-img_5315.jpg', 'Tim operasional BINNET'], ['/media/6066-img_5343.jpg', 'Penanganan di area pelanggan'], ['/media/6059-img_5407.jpg', 'Layanan pelanggan'], ['/media/6062-img_5451.jpg', 'Pemeriksaan perangkat'], ['/media/6064-img_5421.jpg', 'Tim BINNET'],
      ].map((item, index) => <figure class:list={['gallery-item reveal-media', { wide: index === 0 || index === 3 }]}><img src={item[0]} alt={item[1]} loading="lazy" /><figcaption><span>{String(index + 1).padStart(2, '0')}</span>{item[1]}</figcaption></figure>)}
    </div></section>
  )}

  {slug === 'testomonials' && (
    <section class="section all-reviews"><div class="container review-stack">
      {testimonials.map((item, index) => <blockquote class="full-review reveal"><span>{String(index + 1).padStart(2, '0')}</span><p>“{item.quote}”</p><footer><strong>{item.name}</strong><small>{item.profession}</small></footer></blockquote>)}
    </div></section>
  )}
</Layout>

<style>
  .story-section, .service-detail-section, .pricing-page, .coverage-section, .contact-section, .faq-section, .gallery-section, .all-reviews { background: var(--white); }
  .split-story { display: grid; grid-template-columns: .8fr 1.2fr; gap: clamp(3rem, 10vw, 10rem); align-items: start; }
  .story-sticky { position: sticky; top: 8rem; }
  .story-copy { display: grid; gap: 2rem; color: var(--muted); }
  .story-copy .large-copy { color: var(--ink); font-family: 'Space Grotesk'; font-size: clamp(1.8rem, 3.8vw, 3.5rem); letter-spacing: -.05em; line-height: 1.18; }
  .team-mosaic { display: grid; min-height: 100svh; grid-template-columns: 1.2fr .8fr; grid-template-rows: 1fr 1fr; gap: 2px; background: var(--ink); }
  .team-mosaic > div { position: relative; overflow: hidden; }
  .team-mosaic img { width: 100%; height: 100%; object-fit: cover; }
  .mosaic-wide { grid-row: 1 / 3; }
  .mosaic-tall { grid-row: 1; }
  .mosaic-small { grid-row: 2; }
  .mosaic-note { position: absolute !important; right: 4vw; bottom: 4vw; max-width: 320px; padding: 2rem; border-radius: 24px; background: var(--lime); }
  .mosaic-note span { font-family: 'Space Grotesk'; font-size: 5rem; letter-spacing: -.08em; line-height: .8; }
  .mosaic-note p { margin-top: 1rem; font-size: .8rem; }
  .values-section { background: var(--paper); }
  .value-grid { display: grid; grid-template-columns: repeat(3, 1fr); margin-top: 3rem; border-top: 1px solid var(--line); border-left: 1px solid var(--line); }
  .value-grid article { min-height: 330px; padding: 1.5rem; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .value-grid span { color: var(--cyan-deep); font-size: .65rem; }
  .value-grid h3 { margin: 5rem 0 1rem; font-family: 'Space Grotesk'; font-size: 2rem; letter-spacing: -.045em; }
  .value-grid p { color: var(--muted); font-size: .8rem; }

  .service-detail-grid { display: grid; gap: 8rem; }
  .service-detail { display: grid; grid-template-columns: 1.05fr .95fr; gap: clamp(2rem, 8vw, 8rem); align-items: center; }
  .service-detail:nth-child(even) .service-detail-media { order: 2; }
  .service-detail-media { overflow: hidden; aspect-ratio: 4 / 3; border-radius: 28px; }
  .service-detail-media img { width: 100%; height: 100%; object-fit: cover; }
  .service-detail-copy > span { color: var(--cyan-deep); font-size: .7rem; font-weight: 800; }
  .service-detail-copy h2 { margin: 1rem 0; font-family: 'Space Grotesk'; font-size: clamp(2.6rem, 5vw, 5.5rem); font-weight: 600; letter-spacing: -.065em; line-height: .95; }
  .service-detail-copy p { color: var(--muted); }
  .service-detail-copy ul { display: grid; gap: .65rem; margin: 2rem 0; padding: 0; list-style: none; font-size: .76rem; }
  .service-detail-copy li { padding-bottom: .65rem; border-bottom: 1px solid var(--line); }
  .service-detail-copy li::before { margin-right: .7rem; color: var(--lime); content: '●'; }
  .service-detail-copy a { display: inline-block; padding-bottom: .3rem; border-bottom: 1px solid; font-size: .75rem; font-weight: 800; }

  .pricing-feature { display: grid; grid-template-columns: 1fr; align-items: center; margin-bottom: clamp(5rem, 10vw, 9rem); padding: clamp(1.5rem, 4vw, 3.5rem); border-radius: 30px; background: #0b4fa8; color: var(--white); }
  .pricing-feature .eyebrow { color: var(--lime); }
  .pricing-feature h2 { max-width: 720px; font-family: 'Space Grotesk'; font-size: clamp(2.5rem, 5vw, 5.5rem); font-weight: 600; letter-spacing: -.065em; line-height: .95; }
  .pricing-feature > div > p:last-child { max-width: 600px; margin-top: 1.5rem; color: rgba(255,255,255,.6); font-size: .85rem; }
  .pricing-feature-image { width: min(100%, 380px); justify-self: end; border-radius: 22px; box-shadow: 0 28px 70px rgba(0,0,0,.35); transform: rotate(2deg); transition: transform .6s var(--ease); }
  .pricing-feature-image:hover { transform: rotate(0) translateY(-6px); }
  .pricing-feature-image img { width: 100%; border-radius: inherit; }
  .pricing-note { display: grid; grid-template-columns: .3fr 1fr; gap: 2rem; margin-bottom: 3rem; padding-bottom: 1rem; border-bottom: 1px solid var(--line); }
  .pricing-note span { color: var(--cyan-deep); font-size: .65rem; font-weight: 800; text-transform: uppercase; }
  .pricing-note p { font-family: 'Space Grotesk'; font-size: clamp(1.25rem, 2.4vw, 2.2rem); letter-spacing: -.035em; }
  .price-table { border-top: 1px solid var(--line); }
  .price-row { display: grid; grid-template-columns: 50px .8fr 1.3fr .8fr 80px; gap: 2rem; align-items: center; min-height: 165px; padding: 1rem 1.3rem; border-bottom: 1px solid var(--line); transition: background .35s, color .35s; }
  .price-row:hover, .price-row.picked { background: var(--ink); color: var(--white); }
  .price-index { color: var(--muted); font-size: .65rem; }
  .price-speed { display: flex; align-items: baseline; gap: .4rem; }
  .price-speed strong { font-family: 'Space Grotesk'; font-size: clamp(3rem, 5vw, 5rem); font-weight: 500; letter-spacing: -.07em; }
  .price-speed span { font-size: .65rem; font-weight: 800; }
  .price-use { display: grid; }
  .price-use b { font-family: 'Space Grotesk'; font-size: 1.2rem; }
  .price-use span { color: var(--muted); font-size: .7rem; }
  .price-value { display: grid; grid-template-columns: auto 1fr; align-items: baseline; }
  .price-value s { grid-column: 1 / -1; color: var(--red); font-size: .65rem; }
  .price-value strong { font-family: 'Space Grotesk'; font-size: 2rem; }
  .price-value span { color: var(--muted); font-size: .6rem; }
  .price-row > a { font-size: .72rem; font-weight: 800; }
  .fine-print { margin-top: 1rem; color: var(--muted); font-size: .65rem; }
  .package-help { background: var(--cyan); }
  .help-grid { display: grid; grid-template-columns: 1.2fr .8fr; gap: 5rem; align-items: end; }
  .help-grid .lead { color: rgba(7,22,33,.68); }
  .help-grid .button { margin-top: 2rem; }

  .coverage-grid { display: grid; grid-template-columns: .9fr 1.1fr; gap: clamp(3rem, 10vw, 10rem); }
  .coverage-copy { align-self: start; position: sticky; top: 8rem; }
  .coverage-copy .lead { margin-top: 2rem; }
  .coverage-badges { display: flex; gap: .6rem; flex-wrap: wrap; margin-top: 2rem; }
  .coverage-badges span { padding: .55rem .8rem; border: 1px solid var(--line); border-radius: 999px; color: var(--muted); font-size: .65rem; }
  .coverage-form { display: grid; gap: 1.5rem; padding: clamp(1.5rem, 4vw, 3rem); border-radius: 28px; background: var(--paper); }
  .coverage-form label { display: grid; gap: .5rem; }
  .coverage-form label span { font-size: .68rem; font-weight: 800; }
  .coverage-form label i { color: var(--muted); font-style: normal; font-weight: 500; }
  .coverage-form input, .coverage-form textarea { width: 100%; border: 0; border-bottom: 1px solid var(--line); outline: 0; padding: .8rem 0; resize: vertical; background: transparent; color: var(--ink); }
  .coverage-form input:focus, .coverage-form textarea:focus { border-color: var(--cyan-deep); }
  .coverage-form small { color: var(--muted); font-size: .6rem; }

  .contact-grid { display: grid; grid-template-columns: 1.3fr .7fr; gap: 6rem; }
  .contact-label, .contact-secondary span { color: var(--cyan-deep); font-size: .65rem; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; }
  .contact-primary > a { position: relative; display: block; margin-top: 2rem; font-family: 'Space Grotesk'; font-size: clamp(4rem, 10vw, 10rem); font-weight: 600; letter-spacing: -.08em; line-height: .78; }
  .contact-primary i { color: var(--cyan); font-size: .25em; font-style: normal; vertical-align: top; }
  .contact-secondary { display: grid; align-content: start; gap: 3rem; padding-top: 2rem; }
  .contact-secondary > div { display: grid; gap: .8rem; padding-bottom: 2rem; border-bottom: 1px solid var(--line); }
  .contact-secondary a, .contact-secondary p { color: var(--muted); font-size: .8rem; }

  .faq-grid { display: grid; grid-template-columns: .65fr 1.35fr; gap: clamp(3rem, 10vw, 10rem); }
  .faq-sticky { position: sticky; top: 8rem; height: fit-content; }
  .faq-sticky .button { margin-top: 2rem; }
  .faq-list { border-top: 1px solid var(--line); }
  .faq-list details { border-bottom: 1px solid var(--line); }
  .faq-list summary { display: grid; grid-template-columns: 40px 1fr 30px; gap: 1rem; align-items: center; padding: 1.8rem 0; cursor: pointer; list-style: none; }
  .faq-list summary::-webkit-details-marker { display: none; }
  .faq-list summary span { color: var(--cyan-deep); font-size: .65rem; }
  .faq-list summary b { font-family: 'Space Grotesk'; font-size: clamp(1.05rem, 2vw, 1.45rem); }
  .faq-list summary i { font-style: normal; font-size: 1.4rem; transition: transform .3s; }
  .faq-list details[open] summary i { transform: rotate(45deg); }
  .faq-list details > p { padding: 0 3rem 2rem 3.5rem; color: var(--muted); font-size: .86rem; }

  .gallery-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 4rem 1.5rem; }
  .gallery-item.wide { grid-column: 1 / -1; }
  .gallery-item img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; border-radius: 22px; }
  .gallery-item.wide img { aspect-ratio: 16 / 8; }
  .gallery-item figcaption { display: flex; gap: 1rem; margin-top: .8rem; font-size: .72rem; font-weight: 800; }
  .gallery-item figcaption span { color: var(--cyan-deep); }

  .review-stack { border-top: 1px solid var(--line); }
  .full-review { display: grid; grid-template-columns: 55px 1fr .25fr; gap: 3rem; align-items: start; padding: 3rem 0; border-bottom: 1px solid var(--line); }
  .full-review > span { color: var(--cyan-deep); font-size: .65rem; }
  .full-review > p { max-width: 850px; font-family: 'Space Grotesk'; font-size: clamp(1.5rem, 3.3vw, 3rem); letter-spacing: -.045em; line-height: 1.2; }
  .full-review footer { display: grid; font-size: .72rem; }
  .full-review footer small { color: var(--muted); }

  @media (max-width: 850px) {
    .split-story, .service-detail, .coverage-grid, .contact-grid, .faq-grid, .help-grid, .pricing-feature { grid-template-columns: 1fr; }
    .story-sticky, .coverage-copy, .faq-sticky { position: static; }
