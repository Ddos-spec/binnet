---
import Layout from '../layouts/Layout.astro';
import summary from '../data/summary.json';

// Astro-native: glob semua .md files at build time
const rawFiles = import.meta.glob('../data/pages/*.md', { query: '?raw', import: 'default', eager: true });

export async function getStaticPaths() {
  return summary.pages.map((page: any) => ({
    params: { slug: page.slug },
    props: { pageInfo: page },
  }));
}

interface Props {
  pageInfo: {
    id: number;
    title: string;
    slug: string;
    status: string;
    link: string;
  };
}

const { pageInfo } = Astro.props;
const { slug } = Astro.params;

// Find matching file from glob results
const matchKey = Object.keys(rawFiles).find(k => k.includes(`-${slug}.md`));
const rawContent = matchKey ? (rawFiles[matchKey] as string) : '';

// Strip YAML frontmatter
const fmEnd = rawContent.indexOf('\n---\n', 4);
const body  = fmEnd > -1 ? rawContent.slice(fmEnd + 5).trim() : rawContent;

// Rewrite WP image URLs → local /media/
const htmlContent = body.replace(
  /https?:\/\/binnet\.biz\.id\/wp-content\/uploads\/[^\s"'<>]*/g,
  (match) => `/media/${match.split('/').pop() || ''}`
);
---

<Layout title={pageInfo.title}>
  <div class="page-hero">
    <h1>{pageInfo.title}</h1>
    <a href={pageInfo.link} target="_blank" rel="noopener" class="page-src-link">
      ↗ binnet.biz.id/{pageInfo.slug}/
    </a>
  </div>

  <div class="wp-content">
    {htmlContent
      ? <Fragment set:html={htmlContent} />
      : <p class="empty-notice">Konten halaman ini belum tersedia.</p>
    }
  </div>
</Layout>

<style>
  .page-hero {
    background: linear-gradient(135deg, #0d2b5e 0%, #1a3c6e 60%, #1e5bb4 100%);
    color: #fff;
    padding: 3.5rem 2rem;
    text-align: center;
  }
  .page-hero h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 900;
    margin-bottom: .6rem;
  }
  .page-src-link {
    color: rgba(255,255,255,.5);
    font-size: .8rem;
    text-decoration: none;
    transition: color .2s;
  }
  .page-src-link:hover { color: rgba(255,255,255,.8); }

  .wp-content {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }
  .wp-content :global(img)  { max-width: 100%; border-radius: 8px; }
  .wp-content :global(h1),
  .wp-content :global(h2),
  .wp-content :global(h3)   { color: #1a3c6e; margin: 1.5rem 0 .75rem; }
  .wp-content :global(p)    { color: #374151; margin-bottom: 1rem; }
  .wp-content :global(a)    { color: #1e5bb4; }

  /* Hide Elementor/WooCommerce junk */
  .wp-content :global(.elementor-shortcode),
  .wp-content :global([data-elementor-type]),
  .wp-content :global(.woocommerce) { display: none; }

  .empty-notice {
    text-align: center;
    color: #94a3b8;
    padding: 5rem 0;
  }
</style>
