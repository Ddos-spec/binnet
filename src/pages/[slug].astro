---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import { fileURLToPath } from 'node:url';
import path from 'node:path';

// Resolve relative to THIS file (works locally & on Vercel)
const __dirname = path.dirname(fileURLToPath(import.meta.url));
const DATA_DIR  = path.resolve(__dirname, '../data');

export async function getStaticPaths() {
  const summary = JSON.parse(
    fs.readFileSync(path.join(DATA_DIR, 'summary.json'), 'utf-8')
  );
  return summary.pages.map((page: any) => ({
    params: { slug: page.slug },
    props: { pageInfo: page },
  }));
}

interface Props {
  pageInfo: {
    id: number;
    title: string;
    slug: string;
    status: string;
    link: string;
  };
}

const { pageInfo } = Astro.props;
const { slug } = Astro.params;

// Read .md file content
const pagesDir = path.join(DATA_DIR, 'pages');
const files = fs.readdirSync(pagesDir);
const matchFile = files.find(f => f.includes(`-${slug}.md`));

let htmlContent = '';

if (matchFile) {
  const raw = fs.readFileSync(path.join(pagesDir, matchFile), 'utf-8');
  // Strip YAML frontmatter
  const fmEnd = raw.indexOf('\n---\n', 4);
  const body  = fmEnd > -1 ? raw.slice(fmEnd + 5).trim() : raw;
  // Rewrite WP image URLs → local /media/
  htmlContent = body.replace(
    /https?:\/\/binnet\.biz\.id\/wp-content\/uploads\/[^\s"'<>]*/g,
    (match) => `/media/${match.split('/').pop() || ''}`
  );
}
---

<Layout title={pageInfo.title}>
  <div class="page-hero">
    <h1>{pageInfo.title}</h1>
    <p>
      <a href={pageInfo.link} target="_blank" rel="noopener"
        style="color:rgba(255,255,255,.55);font-size:.8rem;">
        ↗ binnet.biz.id/{pageInfo.slug}/
      </a>
    </p>
  </div>

  <div class="wp-content">
    {htmlContent
      ? <Fragment set:html={htmlContent} />
      : <p class="empty-notice">Konten halaman ini belum tersedia.</p>
    }
  </div>
</Layout>

<style>
  .page-hero {
    background: linear-gradient(135deg, #0d2b5e 0%, #1a3c6e 60%, #1e5bb4 100%);
    color: #fff;
    padding: 3.5rem 2rem;
    text-align: center;
  }
  .page-hero h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 900;
    margin-bottom: .5rem;
  }

  .wp-content {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }
  .wp-content :global(img) { max-width: 100%; border-radius: 8px; }
  .wp-content :global(h1),
  .wp-content :global(h2),
  .wp-content :global(h3) { color: #1a3c6e; margin: 1.5rem 0 .75rem; }
  .wp-content :global(p)  { color: #374151; margin-bottom: 1rem; }
  .wp-content :global(a)  { color: #1e5bb4; }

  /* Hide Elementor junk */
  .wp-content :global(.elementor-shortcode),
  .wp-content :global([data-elementor-type]),
  .wp-content :global(.elementor-widget-container:empty) { display: none; }

  .empty-notice {
    text-align: center;
    color: #94a3b8;
    padding: 5rem 0;
    font-size: 1rem;
  }
</style>
