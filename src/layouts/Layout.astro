---
// Layout.astro — BINNET faithful rebuild
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'PT Citra Bintang Net — Internet Cepat Harga Hemat' } = Astro.props;
const currentPath = Astro.url.pathname;
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/about-us', label: 'About Us' },
  { href: '/our-services', label: 'Layanan' },
  { href: '/pricing', label: 'Pricelist' },
  { href: '/contact-us', label: 'Kontak' },
];
---

<!doctype html>
<html lang="id">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{title} | BINNET — PT Citra Bintang Net</title>
  <meta name="description" content={description}/>
  <link rel="icon" href="/media/6111-cropped-logo-hd-binnet-transparan-png.png"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue:    #1a3c6e;
      --blue-md: #1e5bb4;
      --blue-lt: #2d7dd2;
      --cyan:    #00b4d8;
      --yellow:  #ffd60a;
      --white:   #ffffff;
      --off:     #f0f4f8;
      --text:    #1a1a2e;
      --muted:   #64748b;
      --radius:  12px;
      --shadow:  0 4px 24px rgba(0,0,0,.10);
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
      color: var(--text);
      background: #fff;
      line-height: 1.6;
    }

    img { max-width: 100%; height: auto; display: block; }
    a { text-decoration: none; color: inherit; }

    .container {
      max-width: 1180px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    .section-label {
      display: inline-block;
      background: rgba(0,180,216,.12);
      color: var(--blue-md);
      font-size: .75rem;
      font-weight: 700;
      letter-spacing: .12em;
      text-transform: uppercase;
      padding: .35rem 1rem;
      border-radius: 999px;
      margin-bottom: 1rem;
    }

    .section-title {
      font-size: clamp(1.6rem, 3.5vw, 2.5rem);
      font-weight: 800;
      color: var(--blue);
      line-height: 1.2;
      margin-bottom: .75rem;
    }

    .section-sub {
      color: var(--muted);
      font-size: 1rem;
      max-width: 560px;
    }

    /* NAVBAR */
    header {
      position: sticky;
      top: 0;
      z-index: 999;
      background: var(--blue);
      box-shadow: 0 2px 20px rgba(0,0,0,.25);
    }

    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 70px;
    }

    .nav-brand {
      display: flex;
      align-items: center;
      gap: .75rem;
    }

    .nav-brand img { height: 42px; width: auto; }

    .nav-brand-text {
      display: flex;
      flex-direction: column;
      line-height: 1.1;
    }

    .nav-brand-text strong {
      color: #fff;
      font-size: 1.1rem;
      font-weight: 800;
    }

    .nav-brand-text span {
      color: var(--cyan);
      font-size: .7rem;
      font-weight: 600;
      letter-spacing: .08em;
      text-transform: uppercase;
    }

    nav ul {
      display: flex;
      gap: .25rem;
      list-style: none;
    }

    nav ul a {
      color: rgba(255,255,255,.85);
      font-size: .9rem;
      font-weight: 500;
      padding: .5rem 1rem;
      border-radius: 8px;
      transition: background .2s, color .2s;
    }

    nav ul a:hover,
    nav ul a.active {
      background: rgba(255,255,255,.12);
      color: #fff;
    }

    .nav-cta {
      background: var(--cyan) !important;
      color: var(--blue) !important;
      font-weight: 700 !important;
      padding: .5rem 1.25rem !important;
    }

    .nav-cta:hover { background: #00d0f0 !important; }

    /* FOOTER */
    footer {
      background: var(--blue);
      color: rgba(255,255,255,.75);
      padding: 4rem 0 0;
      margin-top: 5rem;
    }

    .footer-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 3rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid rgba(255,255,255,.1);
    }

    .footer-brand img { height: 52px; margin-bottom: 1.25rem; }

    .footer-brand p {
      font-size: .9rem;
      line-height: 1.8;
      max-width: 280px;
    }

    .footer-col h4 {
      color: #fff;
      font-size: .9rem;
      font-weight: 700;
      letter-spacing: .06em;
      text-transform: uppercase;
      margin-bottom: 1.25rem;
      padding-bottom: .5rem;
      border-bottom: 2px solid var(--cyan);
      display: inline-block;
    }

    .footer-col ul { list-style: none; }
    .footer-col ul li { margin-bottom: .65rem; }
    .footer-col ul li a {
      font-size: .875rem;
      color: rgba(255,255,255,.65);
      transition: color .2s;
    }
    .footer-col ul li a:hover { color: var(--cyan); }

    .footer-bottom {
      padding: 1.5rem 0;
      text-align: center;
      font-size: .825rem;
    }

    /* WHATSAPP FLOAT */
    .wa-float {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      z-index: 9999;
      width: 58px;
      height: 58px;
      background: #25D366;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 20px rgba(37,211,102,.4);
      transition: transform .2s;
    }
    .wa-float:hover { transform: scale(1.1); }
    .wa-float svg { width: 30px; height: 30px; fill: #fff; }

    @media (max-width: 768px) {
      nav ul { display: none; }
      .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
    }
  </style>
</head>
<body>

<header>
  <div class="container nav-inner">
    <a href="/" class="nav-brand">
      <img src="/media/6111-cropped-logo-hd-binnet-transparan-png.png" alt="BINNET Logo"/>
      <div class="nav-brand-text">
        <strong>BINNET</strong>
        <span>PT Citra Bintang Net</span>
      </div>
    </a>

    <nav>
      <ul>
        {navItems.map(item => (
          <li>
            <a href={item.href} class={currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) ? 'active' : ''}>
              {item.label}
            </a>
          </li>
        ))}
        <li><a href="/contact-us" class="nav-cta">Daftar Sekarang</a></li>
      </ul>
    </nav>
  </div>
</header>

<main>
  <slot/>
</main>

<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <img src="/media/6101-logo-hd-binnet-transparan.png" alt="BINNET"/>
        <p>PT Citra Bintang Net (BINNET) adalah penyedia layanan internet (ISP) yang berkomitmen memberikan koneksi internet cepat, stabil, dan terjangkau untuk rumah dan bisnis Anda.</p>
      </div>
      <div class="footer-col">
        <h4>Layanan</h4>
        <ul>
          <li><a href="/our-services">Internet Rumah</a></li>
          <li><a href="/our-services">Internet Bisnis</a></li>
          <li><a href="/our-services">Pemasangan CCTV</a></li>
          <li><a href="/our-services">Perbaikan Elektronik</a></li>
          <li><a href="/pricing">Pricelist</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Perusahaan</h4>
        <ul>
          <li><a href="/about-us">Tentang Kami</a></li>
          <li><a href="/contact-us">Kontak</a></li>
          <li><a href="/faq">FAQ</a></li>
          <li><a href="/blog-grid">Blog</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Hubungi</h4>
        <ul>
          <li><a href="https://wa.me/6281234567890" target="_blank">WhatsApp</a></li>
          <li><a href="mailto:info@binnet.biz.id">info@binnet.biz.id</a></li>
          <li><a href="/contact-us">Form Kontak</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} PT Citra Bintang Net (BINNET). All rights reserved.</p>
    </div>
  </div>
</footer>

<!-- WhatsApp Float Button -->
<a href="https://wa.me/6281234567890" target="_blank" rel="noopener" class="wa-float" aria-label="Chat WhatsApp">
  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
</a>

</body>
</html>
