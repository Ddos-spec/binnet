---
import { whatsappLink } from '../data/site';

interface Props {
  title: string;
  description?: string;
  image?: string;
  article?: boolean;
}

const {
  title,
  description = 'Internet fiber optic unlimited tanpa FUP dari PT Citra Bintang Net. Stabil, transparan, dan didukung teknisi lokal.',
  image = '/media/generated/blog-router-position.webp',
  article = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
const canonical = new URL(currentPath, 'https://binnet.biz.id').toString();
const pageTitle = title === 'Beranda' ? 'BINNET — Internet Fiber yang Terasa Dekat' : `${title} — BINNET`;
const navItems = [
  { href: '/', label: 'Beranda' },
  { href: '/pricing', label: 'Paket' },
  { href: '/our-services', label: 'Layanan' },
  { href: '/coverage-area', label: 'Area' },
  { href: '/about-us', label: 'Tentang' },
  { href: '/blog', label: 'Jurnal' },
];

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath === href || currentPath.startsWith(`${href}/`);

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'InternetServiceProvider',
  name: 'BINNET — PT Citra Bintang Net',
  url: 'https://binnet.biz.id',
  telephone: '+62-857-7385-4210',
  foundingDate: '2013',
  description,
};
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#071621" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/media/6111-cropped-logo-hd-binnet-transparan-png.png" />
    <meta property="og:locale" content="id_ID" />
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, 'https://binnet.biz.id').toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

    <style is:global>
      :root {
        --ink: #071621;
        --ink-2: #102a3a;
        --paper: #f4f1e9;
        --white: #fffef9;
        --cyan: #35c6f4;
        --cyan-deep: #0795c5;
        --lime: #a7ed52;
        --red: #ed3c34;
        --line: rgba(7, 22, 33, .14);
        --muted: #5e6d74;
        --max: 1320px;
        --radius: 28px;
        --ease: cubic-bezier(.22, 1, .36, 1);
      }

      *, *::before, *::after { box-sizing: border-box; }
      * { margin: 0; }
      html { scroll-behavior: smooth; background: var(--ink); }
      body {
        min-width: 320px;
        overflow-x: hidden;
        background: var(--paper);
        color: var(--ink);
        font-family: 'Manrope', system-ui, sans-serif;
        line-height: 1.6;
        text-rendering: optimizeLegibility;
      }
      body.menu-open { overflow: hidden; }
      img { display: block; max-width: 100%; }
      a { color: inherit; text-decoration: none; }
      button, input, textarea { font: inherit; }
      button { color: inherit; }
      ::selection { background: var(--lime); color: var(--ink); }

      .container { width: min(calc(100% - 48px), var(--max)); margin-inline: auto; }
      .display {
        font-family: 'Space Grotesk', sans-serif;
        font-size: clamp(3.3rem, 8.6vw, 8.8rem);
        font-weight: 600;
        letter-spacing: -.075em;
        line-height: .88;
      }
      .section-title {
        max-width: 950px;
        font-family: 'Space Grotesk', sans-serif;
        font-size: clamp(2.45rem, 5.4vw, 5.8rem);
        font-weight: 600;
        letter-spacing: -.06em;
        line-height: .98;
      }
      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: .65rem;
        margin-bottom: 1.25rem;
        font-size: .74rem;
        font-weight: 800;
        letter-spacing: .16em;
        line-height: 1;
        text-transform: uppercase;
      }
      .eyebrow::before { width: 9px; height: 9px; border-radius: 50%; background: var(--lime); content: ''; }
      .lead { max-width: 680px; color: var(--muted); font-size: clamp(1rem, 1.5vw, 1.3rem); line-height: 1.65; }
      .muted { color: var(--muted); }
      .button {
        display: inline-flex;
        min-height: 54px;
        align-items: center;
        justify-content: center;
        gap: .8rem;
        padding: .85rem 1.35rem;
        border: 1px solid transparent;
        border-radius: 999px;
        background: var(--lime);
        color: var(--ink);
        font-size: .86rem;
        font-weight: 800;
        transition: transform .35s var(--ease), background .35s, color .35s, border-color .35s;
      }
      .button::after { content: '↗'; font-size: 1rem; }
      .button:hover { transform: translateY(-3px); background: var(--cyan); }
      .button-dark { background: var(--ink); color: var(--white); }
      .button-dark:hover { background: var(--ink-2); color: var(--lime); }
      .button-ghost { border-color: currentColor; background: transparent; color: inherit; }
      .button-ghost:hover { border-color: var(--cyan); background: var(--cyan); color: var(--ink); }
      .section { padding-block: clamp(5.5rem, 10vw, 10rem); }

      .site-header {
        position: fixed;
        z-index: 1000;
        top: 0;
        left: 0;
        width: 100%;
        padding-top: 14px;
        pointer-events: none;
        transition: transform .65s var(--ease), opacity .45s;
      }
      .site-header.is-hidden { opacity: 0; transform: translateY(-115%); }
      .nav-shell {
        width: min(calc(100% - 28px), var(--max));
        min-height: 68px;
        margin-inline: auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 9px 10px 9px 18px;
        border: 1px solid rgba(255,255,255,.15);
        border-radius: 999px;
        background: rgba(7,22,33,.78);
        box-shadow: 0 14px 40px rgba(0,0,0,.16);
        backdrop-filter: blur(18px);
        pointer-events: auto;
      }
      .brand { display: flex; align-items: center; gap: .75rem; color: var(--white); }
      .brand img { width: 39px; height: 39px; object-fit: contain; }
      .brand-copy { display: grid; line-height: 1; }
      .brand-copy strong { font-family: 'Space Grotesk'; font-size: 1rem; letter-spacing: .04em; }
      .brand-copy small { margin-top: .35rem; color: rgba(255,255,255,.52); font-size: .58rem; letter-spacing: .11em; text-transform: uppercase; }
      .desktop-nav { display: flex; align-items: center; gap: .2rem; }
      .desktop-nav > a:not(.nav-cta) {
        padding: .75rem .88rem;
        border-radius: 999px;
        color: rgba(255,255,255,.72);
        font-size: .76rem;
        font-weight: 700;
        transition: color .25s, background .25s;
      }
      .desktop-nav > a:hover,
      .desktop-nav > a.active { background: rgba(255,255,255,.1); color: var(--white); }
      .nav-cta { min-height: 46px; margin-left: .35rem; padding-inline: 1.15rem; }
      .menu-button {
        display: none;
        width: 46px;
        height: 46px;
        place-items: center;
        border: 0;
        border-radius: 50%;
        background: var(--lime);
        cursor: pointer;
      }
      .menu-button span, .menu-button span::before {
        display: block;
        width: 18px;
        height: 2px;
        background: var(--ink);
        content: '';
        transition: transform .3s var(--ease);
      }
      .menu-button span::before { transform: translateY(6px); }
      .menu-open .menu-button span { transform: rotate(45deg); }
      .menu-open .menu-button span::before { transform: rotate(90deg); }
      .mobile-nav {
        position: fixed;
        z-index: 999;
        inset: 0;
        display: grid;
        align-content: center;
        gap: .4rem;
        padding: 6.5rem 1.5rem 2rem;
        background: var(--ink);
        color: var(--white);
        opacity: 0;
        pointer-events: none;
        transform: translateY(-18px);
        transition: opacity .35s, transform .5s var(--ease);
      }
      .menu-open .mobile-nav { opacity: 1; pointer-events: auto; transform: none; }
      .mobile-nav a { font-family: 'Space Grotesk'; font-size: clamp(2.4rem, 12vw, 4rem); font-weight: 600; letter-spacing: -.05em; line-height: 1.08; }
      .mobile-nav a.active { color: var(--lime); }
      .mobile-contact { margin-top: 1.5rem; color: rgba(255,255,255,.55); font-family: 'Manrope' !important; font-size: .88rem !important; letter-spacing: 0 !important; }

      main { min-height: 70vh; }
      .page-hero {
        position: relative;
        overflow: hidden;
        min-height: 72vh;
        display: flex;
        align-items: end;
        padding: clamp(11rem, 18vw, 15rem) 0 clamp(4rem, 8vw, 7rem);
        background: var(--ink);
        color: var(--white);
      }
      .page-hero::before {
        position: absolute;
        top: 8%;
        right: -8%;
        width: 48vw;
        aspect-ratio: 1;
        border: 1px solid rgba(53,198,244,.22);
        border-radius: 50%;
        box-shadow: 0 0 100px rgba(53,198,244,.12), inset 0 0 80px rgba(167,237,82,.05);
        content: '';
      }
      .page-hero .container { position: relative; z-index: 1; }
      .page-hero .display { max-width: 1100px; }
      .page-hero .lead { margin-top: 2rem; color: rgba(255,255,255,.63); }

      .reveal { opacity: 0; transform: translateY(36px); transition: opacity .8s var(--ease), transform .8s var(--ease); }
      .reveal.is-visible { opacity: 1; transform: none; }
      .reveal-media { overflow: hidden; clip-path: inset(0 0 100% 0 round 24px); transition: clip-path 1.15s var(--ease); }
      .reveal-media img { transform: scale(1.12); transition: transform 1.4s var(--ease); }
      .reveal-media.is-visible { clip-path: inset(0 0 0 0 round 24px); }
      .reveal-media.is-visible img { transform: scale(1); }

      .split-word {
        display: inline-block;
        opacity: 0;
        transform: translateY(1.05em) rotate(2deg);
        transition: opacity .7s var(--ease), transform .9s var(--ease);
        transition-delay: calc(var(--word-index, 0) * 42ms);
        will-change: transform;
      }
      body.is-ready [data-split].is-split-visible .split-word { opacity: 1; transform: none; }

      .scroll-progress {
        position: fixed;
        z-index: 1200;
        top: 0;
        left: 0;
        width: 100%;
        height: 3px;
        background: linear-gradient(90deg, var(--lime), var(--cyan));
        transform: scaleX(0);
        transform-origin: left;
        pointer-events: none;
      }

      .site-loader, .page-transition {
        position: fixed;
        z-index: 3000;
        inset: 0;
        pointer-events: none;
      }
      .site-loader { display: grid; place-items: center; overflow: hidden; background: var(--ink); color: var(--white); transition: visibility 0s 1.1s; }
      .loader-panel { position: absolute; inset: 0; background: var(--cyan); transform-origin: top; transition: transform 1s var(--ease) .4s; }
      .loader-brand { position: relative; z-index: 1; display: grid; justify-items: center; gap: 1rem; transition: opacity .3s ease .25s, transform .65s var(--ease) .2s; }
      .loader-brand img { width: 78px; height: 78px; object-fit: contain; filter: drop-shadow(0 12px 24px rgba(0,0,0,.22)); }
      .loader-brand span { font-family: 'Space Grotesk'; font-size: .72rem; font-weight: 700; letter-spacing: .24em; text-transform: uppercase; }
      .loader-line { width: 140px; height: 2px; overflow: hidden; background: rgba(255,255,255,.2); }
      .loader-line::after { display: block; width: 100%; height: 100%; background: var(--lime); content: ''; animation: loader-line 1s var(--ease) both; }
      body.is-ready .loader-panel { transform: scaleY(0); }
      body.is-ready .loader-brand { opacity: 0; transform: translateY(-24px); }
      body.is-ready .site-loader { visibility: hidden; }
      body.skip-intro .site-loader { display: none; }
      @keyframes loader-line { from { transform: translateX(-100%); } to { transform: none; } }

      .page-transition { display: grid; grid-template-rows: repeat(4, 1fr); visibility: hidden; }
      .page-transition span { background: var(--cyan); transform: scaleX(0); transform-origin: right; transition: transform .55s var(--ease); }
      .page-transition span:nth-child(2) { transition-delay: 50ms; }
      .page-transition span:nth-child(3) { transition-delay: 100ms; }
      .page-transition span:nth-child(4) { transition-delay: 150ms; }
      body.is-leaving .page-transition { visibility: visible; }
      body.is-leaving .page-transition span { transform: scaleX(1); }

      .cursor-dot, .cursor-ring { position: fixed; z-index: 2500; top: 0; left: 0; border-radius: 50%; pointer-events: none; opacity: 0; }
      .cursor-dot { width: 7px; height: 7px; background: var(--lime); }
      .cursor-ring { width: 42px; height: 42px; border: 1px solid rgba(167,237,82,.8); mix-blend-mode: difference; transition: width .35s var(--ease), height .35s var(--ease), background .35s, border-color .35s; }
      body.has-pointer .cursor-dot, body.has-pointer .cursor-ring { opacity: 1; }
      body.cursor-active .cursor-ring { width: 68px; height: 68px; border-color: transparent; background: var(--white); }

      [data-parallax-scroll] { --scroll-y: 0px; transform: translate3d(0, var(--scroll-y), 0); will-change: transform; }

      .site-footer { position: relative; overflow: hidden; padding: clamp(5rem, 9vw, 9rem) 0 2rem; background: var(--ink); color: var(--white); }
      .footer-kicker { color: var(--lime); }
      .footer-title { max-width: 960px; margin-bottom: 3rem; font-family: 'Space Grotesk'; font-size: clamp(3.2rem, 8vw, 8rem); font-weight: 600; letter-spacing: -.075em; line-height: .9; }
      .footer-title span { color: var(--cyan); }
      .footer-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: clamp(5rem, 10vw, 9rem); }
      .footer-meta {
        display: grid;
        grid-template-columns: 1.5fr repeat(3, 1fr);
        gap: 2rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(255,255,255,.15);
      }
      .footer-brand { max-width: 330px; color: rgba(255,255,255,.55); font-size: .82rem; }
      .footer-brand strong { display: block; margin-bottom: .8rem; color: var(--white); font-family: 'Space Grotesk'; font-size: 1.2rem; }
      .footer-col { display: grid; align-content: start; gap: .55rem; font-size: .78rem; }
      .footer-col b { margin-bottom: .55rem; color: rgba(255,255,255,.4); font-size: .65rem; letter-spacing: .14em; text-transform: uppercase; }
      .footer-col a { width: fit-content; color: rgba(255,255,255,.75); transition: color .25s; }
      .footer-col a:hover { color: var(--lime); }
      .footer-bottom { display: flex; justify-content: space-between; gap: 1rem; margin-top: 4rem; color: rgba(255,255,255,.35); font-size: .68rem; }
      .wa-float {
        position: fixed;
        z-index: 900;
        right: 18px;
        bottom: 18px;
        display: flex;
        align-items: center;
        gap: .7rem;
        min-height: 48px;
        padding: .7rem 1rem;
        border: 1px solid rgba(255,255,255,.25);
        border-radius: 999px;
        background: #22c967;
        box-shadow: 0 14px 30px rgba(0,0,0,.2);
        color: #052413;
        font-size: .74rem;
        font-weight: 800;
        transition: transform .3s var(--ease);
      }
      .wa-float:hover { transform: translateY(-4px); }
      .wa-dot { width: 9px; height: 9px; border-radius: 50%; background: #fff; box-shadow: 0 0 0 5px rgba(255,255,255,.2); }

      @media (max-width: 960px) {
        .desktop-nav { display: none; }
        .menu-button { display: grid; }
        .footer-meta { grid-template-columns: 1fr 1fr; }
      }

      @media (max-width: 640px) {
        .container { width: min(calc(100% - 32px), var(--max)); }
        .nav-shell { width: calc(100% - 20px); padding-left: 13px; }
        .brand-copy small { display: none; }
        .page-hero { min-height: 66vh; }
        .footer-meta { grid-template-columns: 1fr; }
        .footer-bottom { flex-direction: column; }
        .wa-float span:last-child { display: none; }
        .wa-float { width: 50px; justify-content: center; padding: 0; }
        .site-loader .loader-brand img { width: 62px; height: 62px; }
        .split-word { transition-delay: calc(var(--word-index, 0) * 24ms); }
      }

      @media (hover: none), (pointer: coarse) {
        .cursor-dot, .cursor-ring { display: none; }
        [data-parallax-scroll] { transform: none !important; }
      }

      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        *, *::before, *::after { animation-duration: .01ms !important; animation-iteration-count: 1 !important; transition-duration: .01ms !important; }
        .reveal { opacity: 1; transform: none; }
        .reveal-media { clip-path: none; }
        .split-word { opacity: 1; transform: none; }
        .site-loader, .page-transition, .scroll-progress, .cursor-dot, .cursor-ring { display: none; }
      }
    </style>
  </head>
  <body>
    <script is:inline>try{if(sessionStorage.getItem('binnet-intro-seen')==='1')document.body.classList.add('skip-intro')}catch(e){}</script>
    <div class="site-loader" aria-hidden="true">
      <div class="loader-panel"></div>
      <div class="loader-brand"><img src="/media/6111-cropped-logo-hd-binnet-transparan-png.png" alt="" /><span>Connecting home</span><i class="loader-line"></i></div>
    </div>
    <div class="page-transition" aria-hidden="true"><span></span><span></span><span></span><span></span></div>
    <div class="scroll-progress" aria-hidden="true"></div>
    <div class="cursor-dot" aria-hidden="true"></div>
    <div class="cursor-ring" aria-hidden="true"></div>
    <header class="site-header">
      <div class="nav-shell">
        <a href="/" class="brand" aria-label="BINNET beranda">
          <img src="/media/6111-cropped-logo-hd-binnet-transparan-png.png" alt="" width="39" height="39" />
          <span class="brand-copy"><strong>BINNET</strong><small>PT Citra Bintang Net</small></span>
        </a>
        <nav class="desktop-nav" aria-label="Navigasi utama">
          {navItems.map(item => <a href={item.href} class:list={{ active: isActive(item.href) }}>{item.label}</a>)}
          <a class="button nav-cta" href={whatsappLink()} target="_blank" rel="noopener">Cek area</a>
        </nav>
        <button class="menu-button" type="button" aria-label="Buka menu" aria-expanded="false" aria-controls="mobile-nav"><span></span></button>
      </div>
    </header>

    <nav class="mobile-nav" id="mobile-nav" aria-label="Navigasi mobile">
      {navItems.map(item => <a href={item.href} class:list={{ active: isActive(item.href) }}>{item.label}</a>)}
      <a class="mobile-contact" href={whatsappLink()} target="_blank" rel="noopener">WhatsApp · 0857 7385 4210 ↗</a>
    </nav>

    <main><slot /></main>

    <footer class="site-footer">
      <div class="container">
        <p class="eyebrow footer-kicker">Koneksi dimulai dari percakapan</p>
        <h2 class="footer-title">Alamat Anda.<br /><span>Jaringan kami?</span></h2>
        <div class="footer-actions">
          <a class="button" href={whatsappLink()} target="_blank" rel="noopener">Cek jaringan sekarang</a>
          <a class="button button-ghost" href="/pricing">Lihat semua paket</a>
        </div>
        <div class="footer-meta">
          <div class="footer-brand"><strong>BINNET.NET</strong>Internet fiber optic unlimited sejak 2013, dengan tim lokal yang memahami area dan pelanggan secara langsung.</div>
          <div class="footer-col"><b>Jelajahi</b><a href="/pricing">Paket internet</a><a href="/our-services">Layanan</a><a href="/coverage-area">Cek area</a><a href="/blog">Jurnal</a></div>
          <div class="footer-col"><b>Perusahaan</b><a href="/about-us">Tentang kami</a><a href="/faq">Pertanyaan umum</a><a href="/contact-us">Kontak</a></div>
          <div class="footer-col"><b>Terhubung</b><a href={whatsappLink()} target="_blank" rel="noopener">0857 7385 4210</a><a href="https://www.instagram.com/binnetwifi/" target="_blank" rel="noopener">Instagram</a><a href="mailto:info@binnet.biz.id">info@binnet.biz.id</a><span>Pandawa Regency, Tajur Halang, Bogor 16320</span></div>
        </div>
        <div class="footer-bottom"><span>© {new Date().getFullYear()} PT Citra Bintang Net</span><span>Fiber lokal · layanan manusia</span></div>
      </div>
    </footer>

    <a class="wa-float" href={whatsappLink()} target="_blank" rel="noopener" aria-label="Chat BINNET di WhatsApp"><i class="wa-dot"></i><span>Chat WhatsApp</span></a>

    <script>
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const finePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
      const body = document.body;
      const introSeen = sessionStorage.getItem('binnet-intro-seen') === '1';
      requestAnimationFrame(() => window.setTimeout(() => {
        body.classList.add('is-ready');
        sessionStorage.setItem('binnet-intro-seen', '1');
      }, reduceMotion || introSeen ? 0 : finePointer ? 650 : 300));
      window.addEventListener('pageshow', () => body.classList.remove('is-leaving'));

      const menuButton = document.querySelector('.menu-button');
      const mobileLinks = document.querySelectorAll('.mobile-nav a');
      const setMenu = (open: boolean) => {
        body.classList.toggle('menu-open', open);
        menuButton?.setAttribute('aria-expanded', String(open));
        menuButton?.setAttribute('aria-label', open ? 'Tutup menu' : 'Buka menu');
      };
      menuButton?.addEventListener('click', () => setMenu(!body.classList.contains('menu-open')));
      mobileLinks.forEach(link => link.addEventListener('click', () => setMenu(false)));
      window.addEventListener('keydown', event => { if (event.key === 'Escape') setMenu(false); });

      document.querySelectorAll<HTMLElement>('[data-split]').forEach(element => {
        let index = 0;
        const wrapWords = (node: Node) => {
          Array.from(node.childNodes).forEach(child => {
            if (child.nodeType === Node.TEXT_NODE && child.textContent?.trim()) {
              const fragment = document.createDocumentFragment();
              child.textContent.split(/(\s+)/).forEach(part => {
                if (/^\s+$/.test(part)) return fragment.appendChild(document.createTextNode(part));
                if (!part) return;
                const span = document.createElement('span');
                span.className = 'split-word';
                span.style.setProperty('--word-index', String(index++));
                span.textContent = part;
                fragment.appendChild(span);
              });
              child.replaceWith(fragment);
            } else if (child.nodeType === Node.ELEMENT_NODE) wrapWords(child);
          });
        };
        wrapWords(element);
      });

      const items = document.querySelectorAll('.reveal, .reveal-media');
      const splitItems = document.querySelectorAll('[data-split]');
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver(entries => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: .12 });
        items.forEach(item => observer.observe(item));
        const splitObserver = new IntersectionObserver(entries => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-split-visible');
              splitObserver.unobserve(entry.target);
            }
          });
        }, { threshold: .18 });
        splitItems.forEach(item => splitObserver.observe(item));
      } else {
        items.forEach(item => item.classList.add('is-visible'));
        splitItems.forEach(item => item.classList.add('is-split-visible'));
      }

      const progress = document.querySelector<HTMLElement>('.scroll-progress');
      const header = document.querySelector<HTMLElement>('.site-header');
      const parallaxItems = document.querySelectorAll<HTMLElement>('[data-parallax-scroll]');
      let lastScroll = window.scrollY;
      let scrollTick = false;
      const updateScrollMotion = () => {
        const top = window.scrollY;
        const max = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
        if (progress) progress.style.transform = `scaleX(${Math.min(1, top / max)})`;
        header?.classList.toggle('is-hidden', top > lastScroll && top > 160 && !body.classList.contains('menu-open'));
        if (!reduceMotion && finePointer) {
          parallaxItems.forEach(item => {
            const rect = item.getBoundingClientRect();
            if (rect.bottom > -200 && rect.top < window.innerHeight + 200) {
              const speed = Number(item.dataset.speed || .08);
              const offset = (rect.top + rect.height / 2 - window.innerHeight / 2) * -speed;
              item.style.setProperty('--scroll-y', `${offset.toFixed(1)}px`);
            }
          });
        }
        lastScroll = top;
        scrollTick = false;
      };
      window.addEventListener('scroll', () => {
        if (!scrollTick) { requestAnimationFrame(updateScrollMotion); scrollTick = true; }
      }, { passive: true });
      updateScrollMotion();

      if (finePointer && !reduceMotion) {
        const dot = document.querySelector<HTMLElement>('.cursor-dot');
        const ring = document.querySelector<HTMLElement>('.cursor-ring');
        let pointerX = -100, pointerY = -100, ringX = -100, ringY = -100;
        window.addEventListener('pointermove', event => {
          pointerX = event.clientX;
          pointerY = event.clientY;
          body.classList.add('has-pointer');
          if (dot) dot.style.transform = `translate3d(${pointerX - 3.5}px, ${pointerY - 3.5}px, 0)`;
        }, { passive: true });
        const renderCursor = () => {
          ringX += (pointerX - ringX) * .16;
          ringY += (pointerY - ringY) * .16;
          if (ring) ring.style.transform = `translate3d(${ringX - ring.offsetWidth / 2}px, ${ringY - ring.offsetHeight / 2}px, 0)`;
          requestAnimationFrame(renderCursor);
        };
        renderCursor();
        document.querySelectorAll('a, button, summary, [data-cursor]').forEach(item => {
          item.addEventListener('pointerenter', () => body.classList.add('cursor-active'));
          item.addEventListener('pointerleave', () => body.classList.remove('cursor-active'));
        });
        document.querySelectorAll<HTMLElement>('.button, [data-magnetic]').forEach(item => {
          item.addEventListener('pointermove', event => {
            const rect = item.getBoundingClientRect();
            item.style.translate = `${(event.clientX - rect.left - rect.width / 2) * .13}px ${(event.clientY - rect.top - rect.height / 2) * .13}px`;
          });
          item.addEventListener('pointerleave', () => { item.style.translate = ''; });
        });
      }

      document.querySelectorAll<HTMLAnchorElement>('a[href]').forEach(link => {
        link.addEventListener('click', event => {
          if (reduceMotion || event.defaultPrevented || event.metaKey || event.ctrlKey || link.target === '_blank' || link.hasAttribute('download')) return;
          const url = new URL(link.href, window.location.href);
          if (url.origin !== window.location.origin || url.protocol === 'mailto:' || url.pathname === window.location.pathname && url.hash) return;
          event.preventDefault();
          body.classList.add('is-leaving');
          window.setTimeout(() => { window.location.href = url.href; }, 620);
        });
      });
    </script>
  </body>
</html>
